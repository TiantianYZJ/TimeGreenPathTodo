.edit-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  min-height: 100vh;
}

.version-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.version-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 32rpx;
  background: linear-gradient(135deg, #00B26A 0%, #3ddaa0 100%);
  border-radius: 32rpx;
}

.version-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.version-input {
  width: 140rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  background: transparent;
}

.version-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #f8f9fa;
  border-radius: 32rpx;
}

.date-picker text {
  font-size: 26rpx;
  color: #666;
}

.hidden-picker {
  display: none;
}

.content-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3436;
}

.count-badge {
  padding: 4rpx 12rpx;
  background: rgba(0, 178, 106, 0.1);
  border-radius: 32rpx;
  font-size: 22rpx;
  color: #00B26A;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 0rpx 32rpx;
  background: linear-gradient(135deg, #00B26A 0%, #3ddaa0 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 32rpx;
  border: none;
}

.add-btn::after {
  border: none;
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.content-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 32rpx;
}

.item-number {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
}

.item-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d3436;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.remove-btn::after {
  border: none;
}

.remove-btn:active {
  background: #ffebee;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 0;
  color: #999;
}

.empty-hint text {
  font-size: 24rpx;
}

.actions {
  margin-top: 40rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #00B26A 0%, #3ddaa0 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 178, 106, 0.3);
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.9;
}
