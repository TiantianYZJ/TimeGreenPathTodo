page { background: #f5f5f5; }

.detail-container {
  padding: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 26rpx;
}

.label { color: #999; }
.value { color: #333; }
.status-0 { color: #ff9800; }
.status-1 { color: #4caf50; }
.status-2 { color: #999; }

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin: 24rpx 20rpx 12rpx;
}

.content-box {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
  margin: 0 20rpx;
}

.process-area {
  margin-top: 30rpx;
  padding: 0 20rpx;
}

.process-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}
