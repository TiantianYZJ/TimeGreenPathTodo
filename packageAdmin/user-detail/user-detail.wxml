<view class="detail-container">
  <view class="user-header-card">
    <image class="avatar" src="{{user.avatar_url || '/images/avatar.png'}}" mode="aspectFill" />
    <view class="user-basic">
      <view class="nickname-row">
        <text class="nickname">{{user.nickname || '未设置昵称'}}</text>
        <view class="edit-nickname-btn" bindtap="showEditNickname">
          <t-icon name="edit" size="28rpx" color="#667eea" />
        </view>
      </view>
      <text class="user-id">ID: {{user.id}}</text>
    </view>
  </view>
    <view class="user-stats-mini">
      <view class="stat-mini">
        <text class="stat-num">{{stats.totalTodos || 0}}</text>
        <text class="stat-txt">待办</text>
      </view>
      <view class="stat-mini">
        <text class="stat-num">{{stats.completedTodos || 0}}</text>
        <text class="stat-txt">完成</text>
      </view>
      <view class="stat-mini">
        <text class="stat-num">{{stats.assignedTodosCount || 0}}</text>
        <text class="stat-txt">被分配</text>
      </view>
      <view class="stat-mini">
        <text class="stat-num">{{stats.commentsCount || 0}}</text>
        <text class="stat-txt">评论</text>
      </view>
    </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">基本信息</text>
    </view>
    <view class="info-grid">
      <view class="info-item">
        <t-icon name="user" size="32rpx" color="#667eea" />
        <view class="info-content">
          <text class="info-label">OpenID</text>
          <text class="info-value" bindtap="copyOpenid" data-value="{{user.openid}}">{{user.openid || '-'}}</text>
        </view>
      </view>
      <view class="info-item">
        <t-icon name="time" size="32rpx" color="#00B26A" />
        <view class="info-content">
          <text class="info-label">注册时间</text>
          <text class="info-value">{{user.created_at || '-'}}</text>
        </view>
      </view>
      <view class="info-item">
        <t-icon name="refresh" size="32rpx" color="#f5576c" />
        <view class="info-content">
          <text class="info-label">最后同步</text>
          <text class="info-value">{{user.last_sync_at || '-'}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">数据上限</text>
      <t-tag theme="primary" variant="light" size="small">可调整</t-tag>
    </view>
    <view class="limit-grid">
      <view class="limit-card">
        <view class="limit-icon todo">
          <t-icon name="check-circle" size="36rpx" color="#fff" />
        </view>
        <text class="limit-label">待办上限</text>
        <view class="limit-control">
          <button class="limit-btn minus" bindtap="decreaseLimit" data-field="todo_limit">-</button>
          <text class="limit-value">{{limits.todo_limit}}</text>
          <button class="limit-btn plus" bindtap="increaseLimit" data-field="todo_limit">+</button>
        </view>
      </view>
      <view class="limit-card">
        <view class="limit-icon combo">
          <t-icon name="folder" size="36rpx" color="#fff" />
        </view>
        <text class="limit-label">组合上限</text>
        <view class="limit-control">
          <button class="limit-btn minus" bindtap="decreaseLimit" data-field="combo_limit">-</button>
          <text class="limit-value">{{limits.combo_limit}}</text>
          <button class="limit-btn plus" bindtap="increaseLimit" data-field="combo_limit">+</button>
        </view>
      </view>
      <view class="limit-card">
        <view class="limit-icon collab">
          <t-icon name="link" size="36rpx" color="#fff" />
        </view>
        <text class="limit-label">共享上限</text>
        <view class="limit-control">
          <button class="limit-btn minus" bindtap="decreaseLimit" data-field="collab_limit">-</button>
          <text class="limit-value">{{limits.collab_limit}}</text>
          <button class="limit-btn plus" bindtap="increaseLimit" data-field="collab_limit">+</button>
        </view>
      </view>
    </view>
    <button class="save-btn" bindtap="saveLimits">
      <t-icon name="check" size="32rpx" color="#fff" />
      <text>保存修改</text>
    </button>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">徽标管理</text>
      <t-tag theme="primary" variant="light" size="small">称号+颜色</t-tag>
    </view>
    <view class="badge-list">
      <view wx:for="{{badgeTitles}}" wx:for-index="idx" wx:key="idx" class="badge-edit-item">
        <view class="badge-preview" style="color: {{badgeColors[idx]}}; border-color: {{badgeColors[idx]}}">
          <text>{{item}}</text>
        </view>
        <input class="badge-title-input" value="{{item}}" bindinput="onBadgeTitleInput" data-index="{{idx}}" placeholder="称号" />
        <view class="badge-color-group">
          <input class="badge-color-input" value="{{badgeColors[idx]}}" bindinput="onBadgeColorInput" data-index="{{idx}}" placeholder="#RRGGBB" />
          <view class="badge-color-swatch" style="background: {{badgeColors[idx]}}"></view>
        </view>
        <view class="badge-remove" bindtap="removeBadge" data-index="{{idx}}">
          <t-icon name="delete" size="28rpx" color="#ff4757" />
        </view>
      </view>
    </view>
    <view class="badge-actions">
      <button class="badge-add-btn" bindtap="addBadge">
        <t-icon name="add" size="28rpx" color="#667eea" />
        <text>添加徽标</text>
      </button>
      <button class="save-btn" bindtap="saveBadges">
        <t-icon name="check" size="32rpx" color="#fff" />
        <text>保存徽标</text>
      </button>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">待办列表</text>
      <text class="section-count">{{todos.length}}</text>
    </view>
    <view class="list-card" wx:if="{{todos.length > 0}}">
      <view wx:for="{{todos}}" wx:key="id" class="list-item" bindtap="viewTodo" data-todo="{{item}}">
        <view class="item-left">
          <view class="item-icon {{item.completed ? 'completed' : ''}}">
            <t-icon name="{{item.completed ? 'check-circle-filled' : 'circle'}}" size="36rpx" color="{{item.completed ? '#00B26A' : '#ccc'}}" />
          </view>
          <view class="item-content">
            <text class="item-text {{item.completed ? 'completed-text' : ''}}">{{item.text}}</text>
            <text class="item-meta">{{item.set_date}}</text>
          </view>
        </view>
        <t-icon name="chevron-right" size="32rpx" color="#ccc" />
      </view>
    </view>
    <view wx:else class="empty-state">
      <t-icon name="check-circle" size="60rpx" color="#ddd" />
      <text>暂无待办</text>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">创建的组合</text>
      <text class="section-count">{{combos.length}}</text>
    </view>
    <view class="list-card" wx:if="{{combos.length > 0}}">
      <view wx:for="{{combos}}" wx:key="id" class="list-item" bindtap="viewCombo" data-combo="{{item}}">
        <view class="item-left">
          <view class="item-icon combo-icon" style="background: {{item.color || '#4CAF50'}}">
            <t-icon name="{{item.icon || 'folder'}}" size="28rpx" color="#fff" />
          </view>
          <view class="item-content">
            <text class="item-text">{{item.name}}</text>
            <view class="item-tags">
              <text class="tag" wx:if="{{item.is_shared}}">共享</text>
              <text class="item-meta">{{item.todo_count || 0}} 待办</text>
            </view>
          </view>
        </view>
        <t-icon name="chevron-right" size="32rpx" color="#ccc" />
      </view>
    </view>
    <view wx:else class="empty-state">
      <t-icon name="folder" size="60rpx" color="#ddd" />
      <text>暂无组合</text>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">加入的共享组合</text>
      <text class="section-count">{{sharedCombos.length}}</text>
    </view>
    <view class="list-card" wx:if="{{sharedCombos.length > 0}}">
      <view wx:for="{{sharedCombos}}" wx:key="id" class="list-item" bindtap="viewCombo" data-combo="{{item}}">
        <view class="item-left">
          <view class="item-icon combo-icon" style="background: {{item.color || '#4facfe'}}">
            <t-icon name="{{item.icon || 'folder'}}" size="28rpx" color="#fff" />
          </view>
          <view class="item-content">
            <text class="item-text">{{item.name}}</text>
            <view class="item-tags">
              <text class="tag role">{{item.role === 'owner' ? '超管' : item.role === 'admin' ? '管理' : '成员'}}</text>
              <text class="item-meta">{{item.todo_count || 0}} 待办</text>
            </view>
          </view>
        </view>
        <t-icon name="chevron-right" size="32rpx" color="#ccc" />
      </view>
    </view>
    <view wx:else class="empty-state">
      <t-icon name="link" size="60rpx" color="#ddd" />
      <text>暂无共享组合</text>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">被分配的待办</text>
      <text class="section-count">{{stats.assignedTodosCount || 0}}</text>
      <view class="mode-toggle" bindtap="toggleAssignedMode">
        <t-tag theme="{{showAssignedMode === 'group' ? 'primary' : 'default'}}" variant="light" size="small">
          {{showAssignedMode === 'group' ? '按组合' : '全部'}}
        </t-tag>
      </view>
    </view>
    
    <block wx:if="{{showAssignedMode === 'group'}}">
      <view wx:for="{{assignedTodos}}" wx:key="combo_id" class="combo-group">
        <view class="combo-group-header">
          <view class="combo-icon-small" style="background: {{item.combo_color || '#4facfe'}}">
            <t-icon name="folder" size="24rpx" color="#fff" />
          </view>
          <text class="combo-group-name">{{item.combo_name}}</text>
          <text class="combo-group-count">{{item.todos.length}}个</text>
        </view>
        <view class="list-card">
          <view wx:for="{{item.todos}}" wx:for-item="todo" wx:key="id" class="list-item">
            <view class="item-left">
              <view class="item-icon {{todo.is_completed ? 'completed' : ''}}">
                <t-icon name="{{todo.is_completed ? 'check-circle-filled' : 'circle'}}" size="36rpx" color="{{todo.is_completed ? '#00B26A' : '#ccc'}}" />
              </view>
              <view class="item-content">
                <text class="item-text {{todo.is_completed ? 'completed-text' : ''}}">{{todo.text}}</text>
                <text class="item-meta">{{todo.creator_name ? '创建者: ' + todo.creator_name : ''}} {{todo.set_date || ''}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
    
    <block wx:else>
      <view class="list-card" wx:if="{{assignedTodosFlat.length > 0}}">
        <view wx:for="{{assignedTodosFlat}}" wx:key="id" class="list-item">
          <view class="item-left">
            <view class="item-icon {{item.is_completed ? 'completed' : ''}}">
              <t-icon name="{{item.is_completed ? 'check-circle-filled' : 'circle'}}" size="36rpx" color="{{item.is_completed ? '#00B26A' : '#ccc'}}" />
            </view>
            <view class="item-content">
              <text class="item-text {{item.is_completed ? 'completed-text' : ''}}">{{item.text}}</text>
              <view class="item-tags">
                <text class="tag combo-tag" style="background: {{item.combo_color || '#4facfe'}}20; color: {{item.combo_color || '#4facfe'}}">{{item.combo_name}}</text>
                <text class="item-meta">{{item.set_date || ''}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
    
    <view wx:if="{{assignedTodos.length === 0 && assignedTodosFlat.length === 0}}" class="empty-state">
      <t-icon name="assignment" size="60rpx" color="#ddd" />
      <text>暂无被分配的待办</text>
    </view>
  </view>
  
  <view class="section">
    <view class="section-header">
      <text class="section-title">发送的评论</text>
      <text class="section-count">{{stats.commentsCount || 0}}</text>
    </view>
    <view class="list-card" wx:if="{{comments.length > 0}}">
      <view wx:for="{{comments}}" wx:key="id" class="list-item comment-item">
        <view class="comment-icon">
          <t-icon name="{{item.parent_id ? 'chat' : 'comment'}}" size="32rpx" color="{{item.parent_id ? '#667eea' : '#00B26A'}}" />
        </view>
        <view class="item-content">
          <text class="comment-text">{{item.content}}</text>
          <view class="item-tags">
            <text class="tag combo-tag" style="background: #667eea20; color: #667eea">{{item.combo_name}}</text>
            <text wx:if="{{item.parent_content}}" class="reply-hint">回复: {{item.parent_content}}</text>
          </view>
          <text class="item-meta">{{item.created_at}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <t-icon name="chat" size="60rpx" color="#ddd" />
      <text>暂无评论</text>
    </view>
  </view>
  
  <t-popup visible="{{editNicknameVisible}}" bind:visible-change="hideEditNickname" placement="bottom">
    <view class="edit-popup">
      <view class="popup-header">
        <text class="popup-title">修改昵称</text>
        <view class="popup-close" bindtap="hideEditNickname">
          <t-icon name="close" size="36rpx" color="#999" />
        </view>
      </view>
      <view class="popup-body">
        <input 
          class="nickname-input" 
          placeholder="请输入新昵称" 
          value="{{editNicknameValue}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
        <text class="input-hint">最多20个字符</text>
      </view>
      <view class="popup-footer">
        <button class="cancel-btn" bindtap="hideEditNickname">取消</button>
        <button class="confirm-btn" bindtap="saveNickname">保存</button>
      </view>
    </view>
  </t-popup>
</view>
