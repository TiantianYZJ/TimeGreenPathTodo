.changelog-container {
  padding-bottom: 140rpx;
  min-height: 100vh;
}

.header {
  padding: 30rpx 28rpx;
  margin-bottom: 10rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #2d3436;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

.changelog-list {
  display: flex;
  flex-direction: column;
  margin: 20rpx;
  gap: 20rpx;
}

.version-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.version-card:active {
  background: #fafafa;
}

.version-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.version-badge {
  width: 120rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #00B26A 0%, #3ddaa0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.version-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.version-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.version-date {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3436;
}

.version-count {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.version-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.action-btn::after {
  border: none;
}

.action-btn.edit {
  background: rgba(0, 178, 106, 0.1);
}

.action-btn.delete {
  background: rgba(245, 87, 108, 0.1);
}

.action-btn:active {
  opacity: 0.7;
}

.version-preview {
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.change-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.change-item:last-child {
  margin-bottom: 0;
}

.change-dot {
  color: #00B26A;
  font-size: 24rpx;
  line-height: 1.6;
}

.change-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.more-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 120rpx 0;
  color: #999;
}

.empty-state text {
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  color: #bbb !important;
}
