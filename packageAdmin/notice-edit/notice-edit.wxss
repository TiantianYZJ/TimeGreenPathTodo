.edit-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  min-height: 100vh;
}

.type-selector {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.type-option {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.type-option.active {
  border-color: #00B26A;
  background: rgba(0, 178, 106, 0.05);
}

.type-option text {
  font-size: 26rpx;
  color: #666;
}

.type-option.active text {
  color: #00B26A;
  font-weight: 500;
}

.form-section {
  margin-top: 20rpx;
}

.form-section .section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3436;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.form-card {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #2d3436;
}

.required {
  color: #f5576c;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #2d3436;
}

.picker {
  color: #2d3436;
  font-size: 28rpx;
}

.content-section {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.content-header .section-title {
  margin-bottom: 0;
}

.view-toggle {
  display: flex;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 4rpx;
}

.toggle-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #999;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.toggle-btn.active {
  background: #00B26A;
  color: #fff;
}

.editor-wrapper {
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.md-toolbar {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #eee;
  flex-wrap: wrap;
  gap: 8rpx;
}

.toolbar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #e0e0e0;
  transition: all 0.2s;
}

.toolbar-btn:active {
  background: #e8f5e9;
  border-color: #00B26A;
}

.toolbar-icon {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
}

.toolbar-divider {
  width: 1rpx;
  height: 40rpx;
  background: #ddd;
  margin: 0 8rpx;
}

.content-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #2d3436;
  background: #fff;
  padding: 20rpx;
  box-sizing: border-box;
}

.preview-wrapper {
  min-height: 300rpx;
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 20rpx;
}

.preview-content {
  font-size: 28rpx;
  line-height: 1.8;
}

.preview-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  color: #999;
}

.preview-empty text {
  margin-top: 16rpx;
  font-size: 26rpx;
}

.version-hint {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 32rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.version-hint text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.actions {
  margin-top: 40rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #00B26A 0%, #3ddaa0 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 178, 106, 0.3);
}

.save-btn:active {
  opacity: 0.9;
}
