<view class="notices-container">
  <view class="header">
    <text class="title">公告管理</text>
    <text class="subtitle">共 {{notices.length}} 条公告</text>
  </view>
  
  <view class="notice-list">
    <view wx:for="{{notices}}" wx:key="index" class="notice-card" bindtap="editNotice" data-index="{{index}}">
      <view class="notice-header">
        <view class="notice-icon {{item.version ? 'version-type' : ''}}">
          <t-icon name="{{item.version ? 'history' : 'notification'}}" size="32rpx" color="#fff" />
        </view>
        <view class="notice-info">
          <text class="notice-title">{{item.version ? '版本更新 V' + item.version : (item.title || '未命名公告')}}</text>
          <text class="notice-date">{{item.date || '未知日期'}}</text>
        </view>
        <view class="notice-type-tag">
          <t-tag theme="{{item.version ? 'primary' : 'success'}}" variant="light" size="small">{{item.version ? '版本' : '公告'}}</t-tag>
        </view>
      </view>
      <view class="notice-preview">
        <text wx:if="{{item.version}}">版本更新公告，内容自动生成</text>
        <text wx:elif="{{item.content}}">{{item.content.length > 60 ? item.content.slice(0, 60) + '...' : item.content}}</text>
        <text wx:else>暂无内容</text>
      </view>
      <view class="notice-footer">
        <view class="notice-actions" catchtap="stopPropagation">
          <button class="action-btn edit" catchtap="editNotice" data-index="{{index}}">
            <t-icon name="edit" size="28rpx" color="#00B26A" />
          </button>
          <button class="action-btn delete" catchtap="deleteNotice" data-index="{{index}}">
            <t-icon name="delete" size="28rpx" color="#f5576c" />
          </button>
        </view>
      </view>
    </view>
  </view>
  
  <view wx:if="{{!loading && notices.length === 0}}" class="empty-state">
    <t-icon name="notification" size="80rpx" color="#ddd" />
    <text>暂无公告</text>
    <text class="empty-hint">点击右下角按钮添加公告</text>
  </view>
  
  <t-fab icon="add" bind:click="goToCreate" />
</view>
