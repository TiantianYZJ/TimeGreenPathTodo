@import "../../pages/todo/todo.wxss";

.edit-container {
  padding: 20rpx 30rpx;
  padding-top: 200rpx;
  padding-bottom: 40rpx;
}
.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.user-nickname {
  font-size: 38rpx;
  color: #333;
  font-weight: 500;
}
.title-input {
  width: 100%;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  padding: 16rpx 0 8rpx;
  margin-bottom: 4rpx;
  border: none;
  outline: none;
  background: transparent;
}
.title-input::placeholder {
  color: #bbb;
}
.content-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  line-height: 1.3;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}
.publish-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
  font-weight: 500;
  color: #fff;
  background: #00b26a;
  border: none;
  line-height: 1;
}
.publish-btn[disabled] {
  opacity: 0.4;
}
.publish-btn::after {
  border: none;
}
.upload-section {
  margin-bottom: 20rpx;
}
.image-upload {
  --td-upload-radius: 32rpx;
  --td-upload-add-bg-color: #f8f8f8;
  --td-grid-bg-color: #e3f5eb;
  --td-grid-item-bg-color: #e3f5eb;
}
.image-source-switch {
  display: flex;
  align-items: center;
  justify-content: flex;
  gap: 12rpx;
  padding-top: 8rpx;
  padding-left: 12rpx;
}
.switch-label {
  font-size: 28rpx;
  color: #999;
}
.word-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 10rpx;
}
.picker-row {
  display: flex;
  align-items: center;
  background: #ccebda;
  border-radius: 32rpx;
  gap: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}
.picker-row-selected {
  background: #f0fdf6;
  border-radius: 32rpx;
  padding: 24rpx 20rpx;
  border-top: none;
}
.picker-placeholder {
  font-size: 28rpx;
  color: #999;
}
.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #00b26a;
}
.picker-clear {
  padding: 8rpx;
}

/* ===== 弹窗通用 ===== */
.picker-popup {
  display: flex;
  flex-direction: column;
  max-height: 80vh;
  background: rgba(255,255,255,0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx 32rpx 0 0;
  border: 1rpx solid rgba(255,255,255,0.3);
  overflow: hidden;
}
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.popup-title {
  font-size: 38rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.popup-close {
  padding: 8rpx;
}
.picker-search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 16rpx 32rpx;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  flex-shrink: 0;
}
.picker-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.picker-scroll {
  flex: 1;
  height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.picker-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}
.picker-count {
  font-size: 28rpx;
  color: #999;
}
.picker-confirm-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 36rpx;
  margin: 0;
  font-size: 28rpx;
  color: #fff;
  background: #00b26a;
  border: none;
  border-radius: 32rpx;
  line-height: 1;
}
.picker-confirm-btn::after {
  border: none;
}
.picker-empty {
  padding: 60rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

/* Override t-cell width from imported todo.wxss (720rpx !important conflicts with popup layout) */
.picker-popup .t-cell {
  width: 100% !important;
  box-sizing: border-box;
}

/* ===== 待办选择卡片 ===== */
.picker-popup .todo-item {
  margin: 0 20rpx 16rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  position: relative;
}
.picker-popup .todo-item.completed {
  background: linear-gradient(135deg, #ecfdf5 0%, #90e0b7 100%) !important;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.15);
}
.picker-popup .todo-item.completed .t-cell__title {
  color: #00b26a !important;
  text-decoration: line-through;
}
.picker-popup .todo-item.completed .t-cell__description {
  color: #6b7280 !important;
  opacity: 0.7;
}
.picker-popup .todo-item.completed .t-cell__note {
  color: #9ca3af !important;
}

/* Ensure t-cell right-icon slot positions correctly inside the popup */
.picker-popup .t-cell__right-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}
.picker-popup .priority-bar {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 0 32rpx 32rpx 0;
  pointer-events: none;
  z-index: 2;
}
.picker-popup .priority-bar[data-priority="p1"] { background: #e34d4d; }
.picker-popup .priority-bar[data-priority="p2"] { background: #2196F3; }
.picker-popup .priority-bar[data-priority="p3"] { background: #FF9800; }
.picker-popup .priority-bar[data-priority="p4"],
.picker-popup .priority-bar:not([data-priority]) { background: transparent; }
.picker-popup .star-badge {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 2;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  padding: 6rpx 8rpx 8rpx 10rpx;
  border-radius: 0 0 30rpx 0;
}
.picker-checkbox-wrapper {
  display: flex;
  align-items: center;
  padding-left: 20rpx;
}
.picker-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}
.picker-checkbox.checked {
  background: #00b26a;
  border-color: #00b26a;
}

/* ===== 组合选择 ===== */
.picker-popup .combo-section {
  padding: 16rpx 0;
}
.picker-popup .section-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  padding: 0 32rpx 12rpx;
}
.picker-popup .combo-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  margin: 0 20rpx;
  border-radius: 32rpx;
}
.picker-popup .combo-option.selected {
  background: #f0fdf6;
}
.combo-icon-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.combo-info-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.combo-name-text {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.combo-count-text {
  font-size: 22rpx;
  color: #999;
}

/* ===== 已选待办折叠卡片 ===== */
.picker {
  border-radius: 32rpx;
  background: #ccebda;
  margin-bottom: 12rpx;
}
.selected-todos-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}
.selected-todos-body {
  padding: 0 20rpx 16rpx;
}
.selected-todo-mini-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 12rpx;
}
.selected-todo-mini-item:last-child {
  padding-bottom: 0;
}
.selected-todo-mini-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.selected-todo-mini-dot[data-priority="p1"] { background: #e34d4d; }
.selected-todo-mini-dot[data-priority="p2"] { background: #2196F3; }
.selected-todo-mini-dot[data-priority="p3"] { background: #FF9800; }
.selected-todo-mini-dot[data-priority="p4"],
.selected-todo-mini-dot:not([data-priority]) { background: #9e9e9e; }
.selected-todo-mini-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.selected-todo-remove {
  padding: 8rpx;
}

/* ===== @提及面板（固定定位，不遮键盘） ===== */
.at-suggestions {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  max-height: 45vh;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.1);
  overflow: hidden;
  z-index: 9999;
}
.at-suggestions-header {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.at-suggestions-title { font-size: 28rpx; font-weight: 600; color: #1a1a1a; }
.at-suggestions-close { padding: 8rpx; }
.at-suggestions-scroll { max-height: 36vh; overflow-y: auto; padding: 8rpx 0; }
.at-suggestions-empty { padding: 36rpx; text-align: center; font-size: 28rpx; color: #999; }

/* 共享的@用户项样式 */
.at-user-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 18rpx 24rpx;
}
.at-user-item:active { background: #f5f5f5; }
.at-user-avatar {
  width: 52rpx; height: 52rpx; border-radius: 50%; flex-shrink: 0;
}
.at-user-name { font-size: 28rpx; color: #1a1a1a; }

/* ===== @提及用户卡片 ===== */
.mention-card {
  display: flex; align-items: center; gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #f0fdf6;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.mention-card-text { flex: 1; font-size: 26rpx; color: #333; }
.mention-count { color: #00b26a; font-weight: 600; }

/* ===== @提及用户列表弹窗 ===== */
.mention-list-popup {
  max-height: 60vh;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(16rpx);
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}
.mention-list-header {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 28rpx; border-bottom: 1rpx solid #f0f0f0;
}
.mention-list-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; }
.mention-list-scroll { max-height: 50vh; overflow-y: auto; padding: 8rpx 0; }
.mention-list-item {
  display: flex; align-items: center; gap: 16rpx; padding: 20rpx 28rpx;
}
.mention-list-item:active { background: #f5f5f5; }
.mention-list-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%; background: #eee; flex-shrink: 0;
}
.mention-list-name { flex: 1; font-size: 28rpx; color: #1a1a1a; }
.mention-list-empty { padding: 60rpx; text-align: center; font-size: 28rpx; color: #999; }