@import "../../pages/todo/todo.wxss";

.deleted-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
  gap: 20rpx;
}

.post-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.post-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.post-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.post-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.post-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.post-time {
  font-size: 22rpx;
  color: #999;
}

.time-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.post-ip {
  font-size: 20rpx;
  color: #999;
}
.post-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 12rpx;
}
.post-body {
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
  margin-bottom: 16rpx;
}
.post-images {
  margin-bottom: 16rpx;
}
.detail-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
}
.post-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.edited-badge {
  color: #00b26a;
  font-weight: 500;
}
.location-card {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: #f0fdf6;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #00b26a;
  margin-bottom: 16rpx;
}
.post-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}
.more-btn {
  margin-left: auto;
}
.visitor-link {
  color: #00b26a;
}

.post-tags {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 12rpx 0 8rpx;
}
.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #00b26a;
  background: #f0fdf6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.tag-card {
  width: 100%;
  background: #f0fdf6;
  border-radius: 20rpx;
  overflow: hidden;
}

.tag-card-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
}

.tag-card-title {
  flex: 1;
  font-size: 24rpx;
  color: #00b26a;
}

.tag-card-body {
  padding: 0 16rpx 10rpx;
}

.tag-card-empty {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

.todo-mini-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 0;
  border-top: 1rpx solid rgba(0, 178, 106, 0.1);
}

.todo-mini-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #bbb;
  flex-shrink: 0;
}

.todo-mini-dot[data-priority="p1"] { background: #f44336; }
.todo-mini-dot[data-priority="p2"] { background: #FF9800; }
.todo-mini-dot[data-priority="p3"] { background: #4CAF50; }

.todo-mini-text {
  flex: 1;
  font-size: 24rpx;
  color: #555;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-combo {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #00b26a;
  background: #f0fdf6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

/* 评论区 */
.comment-section {
  padding: 0 20rpx 20rpx;
}
.comment-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 0;
}
.no-comments {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}
.comment-item {
  margin-bottom: 20rpx;
  background: #fff;
  padding: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.comment-deleted {
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
.comment-normal {
  display: flex;
  gap: 16rpx;
}
.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.comment-body {
  flex: 1;
  min-width: 0;
}
.comment-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}
.comment-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}
.comment-actions {
  display: flex;
  align-items: center;
}
.action-btn {
  font-size: 22rpx;
  color: #00b26a;
}
.delete-btn {
  color: #ff4d4f;
}
.comment-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}
.comment-images {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}
.comment-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}
.comment-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
  display: block;
}
.comment-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.comment-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #bbb;
  padding: 4rpx;
}
.comment-like.liked {
  color: #00b26a;
}
.like-count {
  font-size: 20rpx;
  color: inherit;
  min-width: 16rpx;
}
.replies-list {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.reply-item {
  margin-bottom: 12rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-normal {
  display: flex;
  gap: 10rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 4rpx;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.reply-time {
  font-size: 20rpx;
  color: #bbb;
  display: block;
}

.reply-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.5;
}

.reply-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.reply-actions {
  display: flex;
  align-items: center;
}

.loading-comments {
  display: flex;
  justify-content: center;
  padding: 30rpx;
}

.bottom-image-bar {
  background: #fff;
  padding: 8rpx 20rpx 10rpx;
  max-height: 300rpx;
  overflow-y: auto;
}

/* 底部输入栏 */
.bottom-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
  padding: 0rpx 18rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.reply-target {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.reply-target-name {
  color: #00b26a;
  font-weight: 500;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  background: #ddd;
  color: #fff;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  flex-shrink: 0;
}

.send-btn.active {
  background: #00b26a;
}

.send-btn[disabled] {
  opacity: 0.4;
}

.send-btn::after {
  border: none;
}

.close-btn {
  text-align: center;
  padding: 20rpx 0 10rpx;
  font-size: 28rpx;
  color: #999;
}

.visitors-panel {
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  max-height: 600rpx;
  overflow-y: auto;
}
.visitors-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}
.no-visitors {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
.visitor-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.visitor-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}
.visitor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.visitor-nickname {
  font-size: 26rpx;
  color: #333;
}

.nickname-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.user-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 32rpx;
  border: 2rpx solid;
  white-space: nowrap;
  line-height: 1.4;
}
.visitor-time {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.tap-active {
  opacity: 0.6;
}