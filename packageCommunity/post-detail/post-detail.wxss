@import "../../pages/todo/todo.wxss";

/* 卡片容器：包裹 post-card + 统计行 */
.post-card-wrapper {
  background: #fff;
  margin: 20rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  padding: 0 0 30rpx;
}

.deleted-notice {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
  gap: 20rpx;
}

.post-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  padding: 0 30rpx;
}
.edited-badge {
  color: #00b26a;
  font-weight: 500;
}
.post-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding: 16rpx 30rpx 0;
  border-top: 1rpx solid #f0f0f0;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #999;
}
.stat-item.liked {
  color: #ff4757;
}
.more-btn {
  margin-left: auto;
}
.visitor-link {
  color: #00b26a;
}

/* 评论区 */
.comment-section {
  padding: 0 20rpx 64rpx 20rpx;
}
.comment-header {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 16rpx 0;
}
.no-comments {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}
.comment-item {
  margin-bottom: 20rpx;
  background: #fff;
  padding: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.comment-deleted {
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}
.comment-normal {
  display: flex;
  gap: 16rpx;
}
.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.comment-body {
  flex: 1;
  min-width: 0;
}
.comment-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}
.comment-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-right: 8rpx;
}
.comment-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.action-btn {
  font-size: 22rpx;
  color: #00b26a;
  padding: 0;
  border-radius: 0;
}
.delete-btn {
  color: #ff4d4f;
  background: none;
}
.comment-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}
.comment-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
  display: block;
}
.comment-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.comment-like {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #bbb;
  padding: 4rpx;
}
.comment-like.liked {
  color: #ff4d4f;
}
.like-count {
  font-size: 20rpx;
  color: inherit;
  min-width: 16rpx;
}
.replies-list {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
}

.reply-item {
  margin-bottom: 12rpx;
}

.reply-item:last-child {
  margin-bottom: 0;
}

.reply-normal {
  display: flex;
  gap: 10rpx;
}

.reply-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  flex-shrink: 0;
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 4rpx;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-right: 8rpx;
}

.reply-time {
  font-size: 20rpx;
  color: #bbb;
  display: block;
}

.reply-content {
  font-size: 26rpx;
  color: #444;
  line-height: 1.5;
}

.reply-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.reply-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-comments {
  display: flex;
  justify-content: center;
  padding: 30rpx;
}

.bottom-image-bar {
  overflow-y: hidden;
  transition: all 0.3s ease;
  --td-upload-radius: 32rpx;
  --td-upload-add-bg-color: #f8f8f8;
  --td-grid-bg-color: #e3f5eb99;
  --td-grid-item-bg-color: #e3f5eb99;
}
.bar-collapse {
  max-height: 0;
  opacity: 0;
  padding: 0;
}
.bar-expand {
  max-height: 300rpx;
  opacity: 1;
  padding: 8rpx 0;
}

/* 底部输入栏 */
.bottom-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #e3f5eb99;
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  border-top: 1rpx solid rgba(0,0,0,0.05);
  z-index: 100;
  padding: 0rpx 18rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.reply-target {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.reply-target-name {
  color: #00b26a;
  font-weight: 500;
}

.input-wrapper {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  background: #ddd;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  flex-shrink: 0;
}

.send-btn.active {
  background: #00b26a;
}

.send-btn[disabled] {
  opacity: 0.4;
}

.send-btn::after {
  border: none;
}

.close-btn {
  text-align: center;
  padding: 20rpx 0 10rpx;
  font-size: 28rpx;
  color: #999;
}

.visitors-panel {
  padding: 24rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  max-height: 600rpx;
  overflow-y: auto;
}
.visitors-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}
.no-visitors {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}
.visitor-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.visitor-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}
.visitor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.visitor-nickname {
  font-size: 28rpx;
  color: #333;
}

.nickname-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.user-badge {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 32rpx;
  border: 2rpx solid;
  white-space: nowrap;
  line-height: 1.4;
}
.visitor-time {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.tap-active {
  opacity: 0.6;
}

/* @提及链接绿色 */
.comment-content-md .t-chat-markdown-link,
.reply-content-md .t-chat-markdown-link {
  color: var(--primary-color, #00b26a);
}
/* 评论/回复中 t-chat-markdown 继承父级字体 */
.comment-content-md,
.reply-content-md {
  display: block;
  margin: 8rpx 0;
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}