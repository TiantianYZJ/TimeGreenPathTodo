<scroll-view scroll-y class="scroll-view" style="height: calc(100vh - 100rpx);" bind:scrolltolower="onLoadMoreComments"
  refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}" bind:refresherrefresh="onRefresh">
  <view wx:if="{{isDeleted}}" class="deleted-notice">
    <t-icon name="error-circle" size="60rpx" color="#999" />
    <text>该内容因违规已被删除</text>
  </view>

  <view wx:else class="post-card-wrapper">
    <post-card
      post="{{post}}"
      renderMarkdown="{{true}}"
      showStats="{{false}}"
      expanded="{{todoExpanded}}"
      todoItems="{{todoItems}}"
      bind:tapImage="previewImage"
      bind:tapTodoExpand="toggleTodoExpand"
      bind:tapTodo="goToTodoDetail"
      bind:tapCombo="handleComboTap"
      bind:tapLocation="openLocation"
      bind:tapAuthor="onPostTapAuthor"
    />
    <!-- "已编辑" badge -->
    <view wx:if="{{post.isEdited}}" class="post-meta">
      <text class="edited-badge">已编辑</text>
    </view>
    <!-- post-detail 特有的统计行 -->
    <view class="post-stats">
      <view class="stat-item {{isOwner ? 'visitor-link' : ''}}" bind:tap="{{isOwner ? 'showVisitors' : ''}}"><t-icon name="browse" size="28rpx" /><text>{{post.viewsCount}}次浏览{{isOwner ? ' · 查看访客记录' : ''}}</text></view>
      <view class="stat-item {{post.isLiked ? 'liked' : ''}}" catch:tap="toggleLike"><t-icon name="{{post.isLiked ? 'heart-filled' : 'heart'}}" size="28rpx" /><text>{{post.likesCount || 0}}</text></view>
      <view class="stat-item more-btn" bind:tap="onMore"><t-icon name="more" size="36rpx" color="#999" /></view>
    </view>
  </view>

  <view class="comment-section">
    <view class="comment-header">评论 ({{post.commentsCount || 0}})</view>
    <view wx:if="{{comments.length === 0 && !loadingComments}}" class="no-comments"><text>暂无评论，来说点什么吧</text></view>
    <block wx:for="{{comments}}" wx:key="id">
      <view class="comment-item">
        <view wx:if="{{item.isDeleted}}" class="comment-deleted"><text>该评论因违规已被删除</text></view>
        <view wx:else class="comment-normal">
          <image class="comment-avatar" src="{{item.user.avatar || '/images/avatar.png'}}" mode="aspectFill" catch:tap="onCommentTapAuthor" data-user-id="{{item.user.id}}" />
          <view class="comment-body">
            <view class="comment-header-row">
              <view class="nickname-row">
                <text class="comment-nickname" catch:tap="onCommentTapAuthor" data-user-id="{{item.user.id}}">{{item.user.nickname}}</text>
                <block wx:for="{{item.user.badgeTitles || []}}" wx:for-item="badge" wx:key="index">
                  <text class="user-badge" style="color: {{item.user.badgeColors[index]}}; border-color: {{item.user.badgeColors[index]}}">{{badge}}</text>
                </block>
              </view>
              <view class="comment-actions">
                <text wx:if="{{item.canDelete}}" class="action-btn" bind:tap="deleteComment" data-id="{{item.id}}">删除</text>
                <text wx:else class="action-btn" bind:tap="reportComment" data-id="{{item.id}}">举报</text>
                <text class="action-btn" bind:tap="replyComment" data-id="{{item.id}}" data-user="{{item.user.nickname}}" data-userid="{{item.user.id}}">回复</text>
              </view>
            </view>
            <t-chat-markdown class="comment-content-md" content="{{item.content}}" bind:click="onMarkdownClick" />
            <view wx:if="{{item.images && item.images.length > 0}}" class="post-images">
              <view class="grid-{{item.images.length === 1 ? 'single' : (item.images.length === 2 ? 'double' : 'triple')}}">
                <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="{{item.images.length === 1 ? 'widthFix' : 'aspectFill'}}" class="post-image" catch:tap="previewImage" data-url="{{img}}" />
              </view>
            </view>
            <view class="comment-footer">
              <text class="comment-time">{{item._createdDisplay}}</text>
              <view class="comment-like {{item.isLiked ? 'liked' : ''}}" catch:tap="toggleCommentLike" data-id="{{item.id}}">
                <t-icon name="{{item.isLiked ? 'heart-filled' : 'heart'}}" size="24rpx" />
                <text wx:if="{{item.likesCount > 0}}" class="like-count">{{item.likesCount}}</text>
              </view>
            </view>
            <view wx:if="{{item.replies && item.replies.length > 0}}" class="replies-list">
              <view wx:for="{{item.replies}}" wx:for-item="reply" wx:key="id">
                <view class="reply-item">
                  <block wx:if="{{reply.isDeleted}}">
                    <view class="comment-deleted"><text>该评论因违规已被删除</text></view>
                  </block>
                  <block wx:else>
                    <view class="reply-normal">
                      <image class="reply-avatar" src="{{reply.user.avatar || '/images/avatar.png'}}" mode="aspectFill" catch:tap="onCommentTapAuthor" data-user-id="{{reply.user.id}}" />
                      <view class="reply-body">
                        <view class="reply-meta">
                          <view class="nickname-row">
                            <text class="reply-nickname" catch:tap="onCommentTapAuthor" data-user-id="{{reply.user.id}}">{{reply.user.nickname}}</text>
                            <block wx:for="{{reply.user.badgeTitles || []}}" wx:for-item="badge" wx:key="index">
                              <text class="user-badge" style="color: {{reply.user.badgeColors[index]}}; border-color: {{reply.user.badgeColors[index]}}">{{badge}}</text>
                            </block>
                          </view>
                        </view>
                        <t-chat-markdown class="reply-content-md" content="{{reply.content}}" bind:click="onMarkdownClick" />
                        <view wx:if="{{reply.images && reply.images.length > 0}}" class="post-images">
                          <view class="grid-{{reply.images.length === 1 ? 'single' : (reply.images.length === 2 ? 'double' : 'triple')}}">
                            <image wx:for="{{reply.images}}" wx:for-item="rimg" wx:key="*this" src="{{rimg}}" mode="{{reply.images.length === 1 ? 'widthFix' : 'aspectFill'}}" class="post-image" catch:tap="previewImage" data-url="{{rimg}}" />
                          </view>
                        </view>
                        <view class="reply-footer">
                          <text class="reply-time">{{reply._createdDisplay}}</text>
                          <view class="reply-actions">
                            <text wx:if="{{reply.canDelete}}" class="action-btn delete-btn" bind:tap="deleteComment" data-id="{{reply.id}}">删除</text>
                            <text wx:else class="action-btn delete-btn" bind:tap="reportComment" data-id="{{reply.id}}">举报</text>
                            <text class="action-btn" catch:tap="replyComment" data-id="{{reply.id}}" data-user="{{reply.user.nickname}}" data-userid="{{reply.user.id}}">回复</text>
                            <view class="comment-like {{reply.isLiked ? 'liked' : ''}}" catch:tap="toggleCommentLike" data-id="{{reply.id}}">
                              <t-icon name="{{reply.isLiked ? 'heart-filled' : 'heart'}}" size="24rpx" />
                              <text wx:if="{{reply.likesCount > 0}}" class="like-count">{{reply.likesCount}}</text>
                            </view>
                          </view>
                        </view>
                        <view wx:if="{{reply.replies && reply.replies.length > 0}}" class="replies-list">
                          <view wx:for="{{reply.replies}}" wx:for-item="r2" wx:key="id">
                            <view class="reply-item">
                              <view class="reply-normal">
                                <image class="reply-avatar" src="{{r2.user.avatar || '/images/avatar.png'}}" mode="aspectFill" catch:tap="onCommentTapAuthor" data-user-id="{{r2.user.id}}" />
                                <view class="reply-body">
                                  <view class="reply-meta">
                                    <view class="nickname-row">
                                      <text class="reply-nickname" catch:tap="onCommentTapAuthor" data-user-id="{{r2.user.id}}">{{r2.user.nickname}}</text>
                                      <block wx:for="{{r2.user.badgeTitles || []}}" wx:for-item="badge" wx:key="index">
                                        <text class="user-badge" style="color: {{r2.user.badgeColors[index]}}; border-color: {{r2.user.badgeColors[index]}}">{{badge}}</text>
                                      </block>
                                    </view>
                                  </view>
                                  <t-chat-markdown class="reply-content-md" content="{{r2.content}}" bind:click="onMarkdownClick" />
                                  <view wx:if="{{r2.images && r2.images.length > 0}}" class="post-images">
                                    <view class="grid-{{r2.images.length === 1 ? 'single' : (r2.images.length === 2 ? 'double' : 'triple')}}">
                                      <image wx:for="{{r2.images}}" wx:for-item="rimg" wx:key="*this" src="{{rimg}}" mode="{{r2.images.length === 1 ? 'widthFix' : 'aspectFill'}}" class="post-image" catch:tap="previewImage" data-url="{{rimg}}" />
                                    </view>
                                  </view>
                                  <view class="reply-footer">
                                    <text class="reply-time">{{r2._createdDisplay}}</text>
                                    <view class="reply-actions">
                                      <text wx:if="{{r2.canDelete}}" class="action-btn delete-btn" bind:tap="deleteComment" data-id="{{r2.id}}">删除</text>
                                      <text wx:else class="action-btn delete-btn" bind:tap="reportComment" data-id="{{r2.id}}">举报</text>
                                      <text class="action-btn" catch:tap="replyComment" data-id="{{r2.id}}" data-user="{{r2.user.nickname}}" data-userid="{{r2.user.id}}">回复</text>
                                      <view class="comment-like {{r2.isLiked ? 'liked' : ''}}" catch:tap="toggleCommentLike" data-id="{{r2.id}}">
                                        <t-icon name="{{r2.isLiked ? 'heart-filled' : 'heart'}}" size="24rpx" />
                                        <text wx:if="{{r2.likesCount > 0}}" class="like-count">{{r2.likesCount}}</text>
                                      </view>
                                    </view>
                                  </view>
                                </view>
                              </view>
                            </view>
                          </view>
                        </view>
                      </view>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{loadingComments}}" class="loading-comments"><t-loading loading="{{true}}" size="40rpx" /></view>
  </view>
</scroll-view>

<!-- 评论 @用户搜索面板（在输入栏上方，不遮键盘） -->
<view wx:if="{{commentAtPopup}}" class="comment-at-suggestions">
  <view class="at-suggestions-header">
    <text class="at-suggestions-title">提及用户</text>
    <view class="at-suggestions-close" catch:tap="closeCommentAtPopup">
      <t-icon name="close" size="32rpx" color="#999" />
    </view>
  </view>
  <scroll-view class="at-suggestions-scroll" scroll-y wx:if="{{commentAtResults.length > 0}}">
    <view
      class="at-user-item"
      wx:for="{{commentAtResults}}" wx:key="id"
      catch:tap="selectCommentMention"
      data-id="{{item.id}}"
      data-nickname="{{item.nickname}}"
    >
      <image class="at-user-avatar" src="{{item.avatar || '/images/avatar.png'}}" mode="aspectFill" />
      <text class="at-user-name">{{item.nickname}}</text>
    </view>
  </scroll-view>
  <view wx:else class="at-suggestions-empty">
    <text wx:if="{{!commentAtKeyword}}">输入昵称搜索用户</text>
    <text wx:else>未找到匹配的用户</text>
  </view>
</view>

<view class="bottom-input-bar">
  <view class="bottom-image-bar {{inputFocused ? 'bar-expand' : 'bar-collapse'}}">
    <t-upload
      mediaType="{{['image']}}"
      max="{{9}}"
      files="{{commentFiles}}"
      gridConfig="{{gridConfig}}"
      config="{{uploadConfig}}"
      draggable="{{false}}"
      bind:add="handleCommentImageAdd"
      bind:remove="handleCommentImageRemove"
      bind:click="handleCommentImageClick"
    />
  </view>
  <view wx:if="{{replyTarget}}" class="reply-target">
    <text>回复 <text class="reply-target-name">{{replyTarget}}</text></text>
    <t-icon name="close" size="32rpx" color="#999" catch:tap="cancelReply" />
  </view>
  <view class="input-wrapper">
    <input class="comment-input" placeholder="{{replyTarget ? '回复 ' + replyTarget + '...' : '发表评论...'}}" value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="submitComment" bindfocus="onInputFocus" bindblur="onInputBlur" focus="{{inputFocused}}" />
    <button class="send-btn {{commentText.trim() || commentImageUrls.length > 0 ? 'active' : ''}}" bindtap="submitComment" disabled="{{!commentText.trim() && commentImageUrls.length === 0}}">
      <t-icon name="arrow-up" size="48rpx" color="{{commentText.trim() || commentImageUrls.length > 0 ? '#fff' : '#666'}}" />
    </button>
  </view>
</view>

<t-popup
  visible="{{showVisitorsPopup}}"
  placement="bottom"
  bind:visible-change="onVisitorsClose"
>
  <view class="visitors-panel">
    <view class="visitors-title">访客记录</view>
    <view wx:if="{{visitors.length === 0}}" class="no-visitors"><text>暂无访客记录</text></view>
    <block wx:for="{{visitors}}" wx:for-item="visitor" wx:key="userId">
      <view class="visitor-item">
        <image class="visitor-avatar" src="{{visitor.avatar || '/images/avatar.png'}}" mode="aspectFill" />
        <view class="visitor-info">
          <view class="nickname-row">
            <text class="visitor-nickname">{{visitor.nickname}}</text>
            <block wx:for="{{visitor.badgeTitles || []}}" wx:for-item="badge" wx:key="index">
              <text class="user-badge" style="color: {{visitor.badgeColors[index]}}; border-color: {{visitor.badgeColors[index]}}">{{badge}}</text>
            </block>
          </view>
          <text class="visitor-time">{{visitor._viewedDisplay}}</text>
        </view>
      </view>
    </block>
  </view>
</t-popup>
