.starred-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.star-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.star-count {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}
.star-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.star-item.completed {
  opacity: 0.6;
}
.star-text {
  font-size: 28rpx;
  color: #333333;
}
.star-text.done {
  text-decoration: line-through;
  color: #bbbbbb;
}
.star-meta {
  font-size: 24rpx;
  color: #bbbbbb;
  margin-top: 4rpx;
}
.empty-state {
  padding: 60rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #cccccc;
}
