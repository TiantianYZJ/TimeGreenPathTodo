.stats-card {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.stat-header {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.stat-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.stat-label {
  font-size: 28rpx;
  color: #666;
}
.stat-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.stat-value.rate {
  color: #00b26a;
  font-size: 34rpx;
}

