.calendar-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.calendar-header {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.calendar-days {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}
.day-item {
  width: 33.33%;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
}
.day-date {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-right: 8rpx;
}
.day-count {
  font-size: 24rpx;
  color: #00b26a;
  background-color: #e3f5eb;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}
.empty-state {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #cccccc;
}
