.shared-todo-list {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.combo-name {
  font-size: 34rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.todo-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.todo-text {
  font-size: 28rpx;
  color: #333333;
}
.todo-meta {
  font-size: 24rpx;
  color: #bbbbbb;
  margin-top: 4rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}
.assign-badge {
  background-color: #e3f5eb;
  color: #00b26a;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  font-size: 22rpx;
}
.member-section {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f0;
}
.member-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
}
.member-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
}
.member-name {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}
.member-role {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}
.member-role.owner {
  background-color: #fff3e0;
  color: #ff9800;
}
.member-role.admin {
  background-color: #e3f5eb;
  color: #00b26a;
}
.member-role.member {
  background-color: #f5f5f5;
  color: #999999;
}
.empty-state {
  padding: 60rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #cccccc;
}
