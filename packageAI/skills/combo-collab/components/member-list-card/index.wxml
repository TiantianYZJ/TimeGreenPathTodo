<view class="member-list">
  <view class="member-header">
    <text>👥 成员列表</text>
    <text class="member-count">共 {{items.members ? items.members.length : 0}} 人</text>
  </view>
  <view wx:if="{{items.members && items.members.length > 0}}">
    <view wx:for="{{items.members}}" wx:key="id" class="member-row">
      <view class="member-avatar">{{item.nickname ? item.nickname.slice(0,1) : '?'}}</view>
      <view class="member-info">
        <text class="member-name">{{item.nickname}}</text>
      </view>
      <text class="member-role-badge {{item.role}}">{{item.role === 'owner' ? '超管' : item.role === 'admin' ? '管理' : '成员'}}</text>
    </view>
  </view>
  <view wx:else class="empty-state">
    <text>暂无成员数据</text>
  </view>
</view>
