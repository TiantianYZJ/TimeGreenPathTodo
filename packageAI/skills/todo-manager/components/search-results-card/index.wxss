.search-results {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.search-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.search-count {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}
.result-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.result-check {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #dddddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 14rpx;
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 20rpx;
}
.result-check.checked {
  background-color: #00b26a;
  border-color: #00b26a;
}
.result-body {
  flex: 1;
  min-width: 0;
}
.result-text {
  font-size: 28rpx;
  color: #333333;
}
.result-text.done {
  text-decoration: line-through;
  color: #bbbbbb;
}
.result-item.completed {
  opacity: 0.6;
}
.result-meta {
  font-size: 24rpx;
  color: #bbbbbb;
  margin-top: 4rpx;
}
.empty-state {
  padding: 60rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #cccccc;
}
