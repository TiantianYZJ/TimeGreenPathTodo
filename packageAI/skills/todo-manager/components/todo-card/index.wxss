.todo-detail {
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.todo-status {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}
.todo-status.done {
  background-color: #e3f5eb;
  color: #00b26a;
}
.todo-status.pending {
  background-color: #fff3e0;
  color: #ff9800;
}
.todo-text {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 12rpx;
}
.todo-text.completed {
  text-decoration: line-through;
  color: #bbb;
}
.todo-detail-row {
  margin-bottom: 16rpx;
}
.detail-link {
  font-size: 26rpx;
  color: #00b26a;
}
.todo-meta-row {
  display: flex;
  flex-direction: row;
  margin-bottom: 12rpx;
}
.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.meta-label {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 4rpx;
}
.meta-value {
  font-size: 28rpx;
  color: #666;
}
.todo-remarks {
  font-size: 28rpx;
  color: #666;
  margin-top: 12rpx;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}
.todo-tags {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}
.tag-item {
  font-size: 24rpx;
  color: #00b26a;
  margin-right: 16rpx;
  margin-bottom: 8rpx;
}
.action-bar {
  display: flex;
  flex-direction: row;
  margin-top: 24rpx;
}
.action-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 8rpx;
}
.action-btn.complete {
  background-color: #00b26a;
  color: #fff;
}
.action-btn.delete {
  background-color: #fff;
  color: #ff4444;
  border: 2rpx solid #ff4444;
}
.empty-state {
  padding: 60rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #ccc;
}
