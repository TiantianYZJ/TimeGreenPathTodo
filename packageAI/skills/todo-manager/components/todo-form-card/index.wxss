.todo-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.form-header {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}
.form-body {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}
.form-row {
  display: flex;
  flex-direction: row;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.form-label {
  font-size: 26rpx;
  color: #999999;
  width: 100rpx;
  flex-shrink: 0;
}
.form-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}
.form-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #00b26a;
  text-align: center;
}
