@import '../../pages/todo/todo.wxss';

.container {
  padding: 20rpx;
  padding-bottom: 380rpx;
}

.fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #e3f5eb99;
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  z-index: 100;
  padding: 20rpx;
  box-sizing: border-box;
}

.scrollable-content {
  position: relative;
}

.combo-header {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.combo-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-left: 16rpx;
  flex: 1;
}

.combo-badge {
  font-size: 24rpx;
  color: #00b26a;
  background: rgba(0, 178, 106, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.admin-badge {
  font-size: 22rpx;
  color: #fff;
  background: #ff9800;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.edit-icon {
  margin-left: 16rpx;
  padding: 8rpx;
}

.description-section {
  background: #f8f8f8;
  border-radius: 32rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.description-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.description-label {
  font-size: 28rpx;
  color: #666;
}

.description-content {
  padding: 0 24rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.todo-item {
  margin: 12rpx 0;
}

.todo-item-wrapper {
  margin: 0;
  position: relative;
  overflow: hidden;
}

.requests-section {
  margin-bottom: 20rpx;
}

.request-list {
  margin-top: 16rpx;
}

.request-item {
  display: flex;
  align-items: center;
  padding: 16rpx 18rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.request-item:last-child {
  border-bottom: none;
}

.request-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.request-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.request-name {
  font-size: 28rpx;
  color: #333;
}

.request-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.request-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.action-btn.approve {
  background: #08bd8f;
  color: #fff;
}

.action-btn.reject {
  background: #f5f5f5;
  color: #d90000;
}

.members-section {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.info-row.single {
  display: block;
}

.info-block {
  flex: 1;
  background: #f8f8f8;
  border-radius: 32rpx;
  padding: 8rpx 20rpx;
}

.info-block.full {
  padding: 0;
  background: #ffffff00;
  box-shadow: 0 0 0;
}

.members-block {
  
}

.stats-block {
  
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #0d5e4a;
}

.view-toggle {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.toggle-label {
  font-size: 24rpx;
  color: #666;
}

.members-preview {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: -16rpx;
  border: 4rpx solid #fff;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.member-more {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  margin-left: -16rpx;
  border: 4rpx solid #fff;
}

.invite-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #00B26A, #52f099);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 178, 106, 0.3);
}

.stats-preview {
  display: flex;
  justify-content: space-around;
  margin-top: 14rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #00b26a;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.todo-list {
  margin-top: -16rpx;
}

.assignee-info {
  padding: 8rpx 16rpx;
  background: rgba(0, 178, 106, 0.1);
  border-radius: 16rpx;
  margin-top: 8rpx;
}

.assignee-text {
  font-size: 24rpx;
  color: #00b26a;
}

.assignee-list {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.assignee-label {
  color: #999;
  margin-right: 8rpx;
}

.assignee-names {
  color: #666;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

.combo-actions {
  margin-top: 20rpx;
}

.delete-combo-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 32rpx;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.delete-text {
  font-size: 30rpx;
  color: #ff4d4f;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 12rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.filter-text {
  font-size: 24rpx;
}

.filter-popup {
  width: 600rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.filter-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.filter-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-popup-close {
  padding: 8rpx;
}

.filter-option {
  padding: 0rpx;
}

.filter-option:last-child {
  border-bottom: none;
}

/* ===========================
   优先级左侧弧度色条
   =========================== */
.todo-item-wrapper[data-priority="p1"]::before {
  background: #e34d4d;
}
.todo-item-wrapper[data-priority="p2"]::before {
  background: #2196F3;
}
.todo-item-wrapper[data-priority="p3"]::before {
  background: #FF9800;
}
.todo-item-wrapper[data-priority="p4"]::before {
  background: #999;
}
.todo-item-wrapper:not([data-priority])::before {
  background: transparent;
}
.todo-item-wrapper[data-priority]::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 12rpx;
  height: calc(100% - 24rpx);
  z-index: 1;
  -webkit-mask: radial-gradient(circle at 8rpx center, transparent 5rpx, black 5rpx);
  mask: radial-gradient(circle at 8rpx center, transparent 5rpx, black 5rpx);
}
