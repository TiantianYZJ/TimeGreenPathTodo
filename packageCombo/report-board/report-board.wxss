@import '../../pages/todo/todo.wxss';

.container {
  padding: 0;
}

/* 顶部信息栏 */
.board-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
}

.board-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.board-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-trigger {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #e3f5eb;
  border: 1rpx solid #00b26a;
  border-radius: 32rpx;
}

.filter-trigger:active {
  opacity: 0.7;
}

.filter-trigger-text {
  font-size: 24rpx;
  color: #00b26a;
  font-weight: 500;
}

/* 日历区域 */
.calendar-wrapper {
  background: #e3f5eb;
}

/* 标签页区域 */
.tabs-wrapper {
  padding: 16rpx;
}

/* 报告列表 */
.report-list {
}

.report-item-wrapper {
  margin: 12rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* 筛选弹窗 */
.filter-popup {
  width: 600rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.filter-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.filter-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-popup-close {
  padding: 8rpx;
}

.filter-option {
  padding: 0rpx;
}

.filter-option:last-child {
  border-bottom: none;
}

/* TDesign component overrides to blend with page background */
page {
  --td-cell-bg-color: #e3f5eb;
  --td-tab-nav-bg-color: #e3f5eb;
  --td-swipe-cell-bg-color: transparent;
}
