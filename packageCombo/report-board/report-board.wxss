@import '../../pages/todo/todo.wxss';

.container {
  background: #ffffff;
  min-height: 100vh;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #e3f5eb99;
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  height: 88rpx;
}

.nav-back {
  padding: 8rpx;
  margin-right: 16rpx;
}

.nav-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-right {
  padding: 8rpx;
}

/* 日历区域 */
.calendar-wrapper {
  padding-top: {{navBarHeight}}px;
  background: #f5faf7;
}

/* 标签页区域 */
.tabs-wrapper {
  padding: 16rpx;
}

/* 报告列表 */
.report-list {
  padding-bottom: 240rpx;
}

.report-item-wrapper {
  margin: 12rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* 筛选弹窗 */
.filter-popup {
  width: 600rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.filter-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.filter-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-popup-close {
  padding: 8rpx;
}

.filter-option {
  padding: 0rpx;
}

.filter-option:last-child {
  border-bottom: none;
}
