/* 继承主容器样式 */
.container {
  padding: 20rpx;
  background: #e3f5eb;
  min-height: 100vh;
}

/* 选项卡片 */
.options-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.option-item:last-child {
  border-bottom: none;
}

.option-label {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 长度选择 */
.length-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.length-label {
  display: block;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #333;
}

/* 按钮样式 */
.generate-btn {
  background: #00b26a;
  border-radius: 16rpx;
  margin: 20rpx 0;
}

/* 结果展示 */
.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.password-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  /* 移除 word-break: break-all */
  text-align: center;
  margin-bottom: 20rpx;
  /* 新增换行属性 */
  white-space: pre-wrap;
  word-wrap: break-word;
}

.strength-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  margin: 10rpx auto;
}

.strength-badge.weak {
  background: #fff0ed;
  color: #d54941;
}

.strength-badge.medium {
  background: #fff3e0;
  color: #e37318;
}

.strength-badge.strong {
  background: #e3f9e9;
  color: #2ba471;
}

.copy-btn {
  margin-top: 20rpx;
  border: 2rpx solid #00b26a;
  color: #00b26a;
  border-radius: 16rpx;
}

/* 声明卡片样式 */
.disclaimer-card {
  margin-top: 20rpx;
  padding: 10rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.disclaimer-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2ba471;
  margin-top: 20rpx;
}

.strength-desc view {
  margin: 10rpx 0;
  padding-left: 20rpx;
}

.strength-desc .weak {
  border-left: 4rpx solid #d54941; /* 与弱强度徽章同色 */
}

.strength-desc .medium {
  border-left: 4rpx solid #e37318; /* 与中强度徽章同色 */
}

.strength-desc .strong {
  border-left: 4rpx solid #2ba471; /* 与高强度徽章同色 */
}
