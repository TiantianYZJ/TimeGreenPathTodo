<view class="container">
  <!-- 选项区域 -->
  <view class="options-card">
    <view class="option-item" wx:for="{{options}}" wx:key="index">
      <checkbox 
        data-index="{{index}}"
        checked="{{item.checked}}"
        bindtap="checkboxChange"
      />
      <text class="option-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 长度选择 -->
  <view class="length-card">
    <text class="length-label">密码长度：{{length}}</text>
    <slider 
      min="4"
      max="64" 
      value="{{length}}" 
      bindchanging="lengthChanging"
      activeColor="#00b26a"
    />
  </view>

  <!-- 生成按钮 -->
  <button 
    type="primary" 
    bindtap="generatePassword" 
    class="generate-btn"
  >生成密码</button>

  <!-- 结果展示 -->
  <view class="result-card" wx:if="{{password}}">
    <view 
      class="password-text" 
      style="white-space: pre-wrap; word-wrap: break-word;"
    >{{password}}</view>
    <view class="strength-badge {{strength}}">
      强度：{{ 
        strength == 'weak' ? '弱' : 
        strength == 'medium' ? '中' : '强' 
      }}
    </view>
    <button 
      type="default" 
      bindtap="copyPassword" 
      class="copy-btn"
    >复制密码</button>
  </view>

  <!-- 声明 -->
  <view class="disclaimer-card">
    <view class="disclaimer-title">安全声明</view>
    <view class="disclaimer-item">我们承诺：所有密码生成过程均在本地完成，不会上传任何数据到云端</view>

    <view class="disclaimer-title">密码等级说明</view>
    <view class="strength-desc">
      <view class="weak">弱（{{strengthTips.weak.time}}）：{{strengthTips.weak.desc}}</view>
      <view class="medium">中（{{strengthTips.medium.time}}）：{{strengthTips.medium.desc}}</view>
      <view class="strong">强（{{strengthTips.strong.time}}）：{{strengthTips.strong.desc}}</view>
    </view>
  </view>
</view>
