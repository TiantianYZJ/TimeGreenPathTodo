.top {
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding-bottom: 16rpx;
  position: fixed;
  background: #e3f5eb99;
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  overflow: visible;
}

/* 自定义公告栏样式 */
.custom-notice {
  background: linear-gradient(135deg, #f6ffed 0%, #e8f8f0 100%);
  padding: 8rpx 24rpx;
  margin: 20rpx 20rpx 16rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(45, 212, 191, 0.12);
  border-left: 6rpx solid #2dd4bf;
  position: relative;
  overflow: hidden;
}

.custom-notice::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(45, 212, 191, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.notice-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.notice-icon {
  font-size: 38rpx;
  margin-right: 16rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(45, 212, 191, 0.3));
}

.notice-text {
  flex: 1;
  font-size: 28rpx;
  color: #0d5e4a;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.notice-action {
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  border-left: 1rpx solid rgba(45, 212, 191, 0.2);
}

.action-text {
  color: #2dd4bf;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 6rpx;
}

.action-icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) saturate(100%) hue-rotate(140deg);
}

/* 绿色清新天气卡片样式 */
.weather-card {
  background: linear-gradient(135deg, #3ddaa0 0%, #12b086 100%); /* 清新绿色渐变 */
  border-radius: 32rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 178, 106, 0.15);
  padding: 28rpx;
  color: #ffffff;
}

.weather-card-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 左侧：温度与天气状态 */
.weather-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.temperature {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  margin-right: 24rpx;
}

.weather-info {
  display: flex;
  flex-direction: column;
}

.weather-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
}

/* 右侧：地点与更新时间 */
.weather-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.location {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.location-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
  filter: brightness(0) invert(1); /* 使图标变为白色 */
}

.city {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

.update-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 新增头部样式 */
.header {
  padding: 0 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
}

.title {
  font-size: 50rpx;
  font-weight: 600;
  color: #2d3436;
  flex: 1;
}

.action-group {
  position: absolute;
  display: flex;
  align-items: center;
}

.container {
  padding-top: 260rpx;
  padding-bottom: 400rpx;
  overflow-y: auto;
}

/* 新增搜索框样式 */
.search-container {
  padding-top: 10rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
}

.search-box:active {
  background: #e0e0e0;
}

.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.placeholder-style {
  color: #999;
  font-size: 28rpx;
}

/* 卡片式列表项 */
.todo-item {
  margin: 12rpx 20rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  transition:
    transform 0.3s ease,
    box-shadow 0.3s ease,
    background 0.5s ease,
    background-color 0.5s ease;
  position: relative;
  display: flex;
}

/* 收藏角标样式 */
.star-badge {
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 8rpx;
  border-radius: 0 0 30rpx 0;
  font-weight: 600;
  z-index: 10;
  animation: badgeBounce 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes badgeBounce {
  0% {
    transform: scale(0) rotate(-15deg);
    opacity: 0;
  }
  50% {
    transform: scale(1.1) rotate(5deg);
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

/* 卡片进入动画 */
@keyframes slideInUp {
  0% {
    transform: translateY(40rpx) scale(0.95);
    opacity: 0;
  }
  60% {
    transform: translateY(-8rpx) scale(1.02);
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

/* 卡片移出动画 */
@keyframes slideOutRight {
  0% {
    transform: translateX(0) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateX(120%) scale(0.8);
    opacity: 0;
  }
}

/* 卡片点击波纹动画 */
@keyframes cardPulse {
  0% {
    box-shadow:
      0 4rpx 8rpx rgba(0,0,0,0.1),
      0 0 0 0 rgba(45, 212, 191, 0);
  }
  50% {
    box-shadow:
      0 4rpx 8rpx rgba(0,0,0,0.1),
      0 0 0 12rpx rgba(45, 212, 191, 0.2);
  }
  100% {
    box-shadow:
      0 4rpx 8rpx rgba(0,0,0,0.1),
      0 0 0 24rpx rgba(45, 212, 191, 0);
  }
}

/* 完成态切换动画 */
@keyframes completePulse {
  0% {
    background: linear-gradient(135deg, #ffffff 0%, #f8fdf9 100%);
    transform: scale(1);
  }
  30% {
    background: linear-gradient(135deg, #ecfdf5 0%, #90e0b7 100%);
    transform: scale(0.99);
  }
  70% {
    transform: scale(1.01);
  }
  100% {
    background: linear-gradient(135deg, #ecfdf5 0%, #90e0b7 100%);
    transform: scale(1);
  }
}

/* 完成态首次切换动画类 */
.todo-item.first-complete {
  animation: completePulse 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 添加卡片进入动画类 */
.todo-item.add-animation {
  animation: slideInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 添加卡片移出动画类 */
.todo-item.remove-animation {
  animation: slideOutRight 0.4s cubic-bezier(0.55, 0.085, 0.68, 0.53) forwards;
}

/* 卡片点击效果 */
.todo-item:active {
  animation: cardPulse 0.3s ease;
}

.todo-item .delete-icon:active {
  opacity: 0.6;
}

.todo-content {
  flex: 1;
  margin: 0 0;
}

/* t-cell 的完成态样式（内部文字颜色等） */
.todo-item.completed .t-cell {
  background: transparent !important;
}

/* swipe-cell 的完成态样式（背景色）- 无动画，只有样式 */
.todo-item.completed {
  background: linear-gradient(135deg, #ecfdf5 0%, #90e0b7 100%) !important;
  box-shadow: 0 4rpx 16rpx rgba(76,175,80,0.15);
}

/* 完成态文字样式 */
.todo-item.completed .t-cell__title {
  color: #00b26a !important;
  text-decoration: line-through;
}

.todo-item.completed .t-cell__description {
  color: #6b7280 !important;
  opacity: 0.7;
}

.todo-item.completed .t-cell__note {
  color: #9ca3af !important;
}

.completed-decorate {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #4CAF50;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

@keyframes ripple {
  0% {
    transform: scale(0);
    opacity: 1;
    box-shadow: 0 0 0 6rpx rgba(76,175,80,0.2);
  }
  50% {
    opacity: 0.6;
    box-shadow: 
      0 0 0 12rpx rgba(76,175,80,0.15),
      0 -8rpx 20rpx rgba(76,175,80,0.1);
  }
  100% {
    transform: scale(2.5);
    opacity: 0;
    box-shadow: 
      0 0 0 24rpx rgba(76,175,80,0),
      0 -16rpx 40rpx rgba(76,175,80,0);
  }
}

/* 新增动画效果 */
@keyframes slideIn {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes fadeOut {
  from { transform: scale(1); opacity: 1; }
  to { transform: scale(0.8); opacity: 0; }
}

.add-animation {
  animation: slideIn 0.3s ease forwards;
}

.remove-animation {
  animation: fadeOut 0.3s ease forwards;
}

.todo-item {
  overflow: hidden;
  position: relative;
}

.swipe-content {
  width: 100%;
  transition: transform 0.3s ease;
  display: flex;
  align-items: center;
}

/* 拖动样式 */
.todo-item.dragging {
  z-index: 999;
  transition:
    transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    box-shadow 0.2s ease,
    background 0.2s ease;
  transform: scale(1.03) translateY(-4rpx);
  box-shadow:
    0 20rpx 60rpx rgba(45, 212, 191, 0.3),
    0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.todo-item.dragging .t-cell {
  transition: background-color 0.2s ease;
  background: linear-gradient(135deg, #f0fdf9 0%, #ecfdf5 100%) !important;
}

/* 在header样式后添加 */
.clear-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F3FBF6;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.clear-btn:active {
  background: #f5f5f5;
  transform: scale(0.95);
}

.btn-wrapper {
  height: 100%;
}

.btn {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  width: 110rpx;
  height: 100%;
  color: white;
}

.delete-btn {
  background-color: #e34d59;
}

.edit-btn {
  background-color: #ed7b2f;
}

/* 强制cell填满容器 */
.t-cell {
  min-height: 100rpx !important;
  padding: 20rpx 30rpx !important;
  width: 720rpx !important;
  box-sizing: border-box;
  transition: 
    transform 0.4s cubic-bezier(0.23, 1, 0.32, 1),
    box-shadow 0.4s ease,
    background-color 0.3s ease;
}

/* 标题样式调整 */
.t-cell__title {
  flex: 1;
  min-width: 465rpx;
  max-width: 465rpx;
  margin-right: 10rpx !important;
  transform: translateY(10%);
  font-size: 34rpx !important;  /* 调大字号 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;  /* 新增标题截断 */
}

/* 备注描述样式调整 */
.t-cell__description {
  flex: 1;
  max-width: 420rpx;  /* 增大最大宽度 */
  margin-right: 10rpx !important;
  transform: translateY(-25%);
  font-size: 28rpx !important;  /* 调小字号 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
}

/* 日期样式调整 */
.t-cell__note {
  flex-shrink: 0;
  font-size: 24rpx !important;  /* 调小字号 */
  color: #666 !important;
  margin-top: 8rpx !important;  /* 与备注保持间距 */
}

/* 右侧复选框定位调整 */
.t-cell__right-icon {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.inline {
  display: inline;
}

/* 广告容器样式 */
.ad-container {
  margin: 20rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.ad-container ad-custom {
  width: 100%;
  display: block;
}

/* ===========================
   拖拽功能样式 - 占位符 + 平滑动画
   =========================== */

/* 列表滚动容器 */
.todo-list-scroll {
  width: 100%;
}

/* 拖拽提示 */
.drag-hint {
  position: fixed;
  top: 280rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1001;
  background: rgba(0, 178, 106, 0.9);
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 178, 106, 0.3);
  animation: hintSlideDown 0.3s ease;
}

@keyframes hintSlideDown {
  from {
    transform: translateX(-50%) translateY(-20rpx);
    opacity: 0;
  }
  to {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
}

.drag-hint-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 占位符样式 */
.todo-item.placeholder {
  border: 3rpx dashed #00B26A;
  background: rgba(0, 178, 106, 0.08);
  animation: placeholderPulse 1.2s ease-in-out infinite;
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

@keyframes placeholderPulse {
  0%, 100% {
    background: rgba(0, 178, 106, 0.05);
    border-color: rgba(0, 178, 106, 0.4);
  }
  50% {
    background: rgba(0, 178, 106, 0.15);
    border-color: rgba(0, 178, 106, 0.8);
  }
}

.placeholder-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #00B26A;
}

.placeholder-text {
  font-size: 28rpx;
  color: #00B26A;
  font-weight: 500;
}

/* 浮动拖拽项 */
.dragging-float {
  position: fixed;
  z-index: 1000;
  pointer-events: none;
  width: calc(100vw - 40rpx);
  transition: none;
}

.dragging-content {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow:
    0 20rpx 60rpx rgba(0, 0, 0, 0.25),
    0 8rpx 24rpx rgba(45, 212, 191, 0.2);
  transform: scale(1.03);
  animation: dragLift 0.2s ease;
  position: relative;
  overflow: hidden;
}

@keyframes dragLift {
  from {
    transform: scale(1);
    box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  to {
    transform: scale(1.03);
    box-shadow:
      0 20rpx 60rpx rgba(0, 0, 0, 0.25),
      0 8rpx 24rpx rgba(45, 212, 191, 0.2);
  }
}

/* 浮动项中的收藏角标 */
.dragging-content .star-badge {
  position: absolute;
  top: 0;
  left: 0;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
  font-size: 22rpx;
  padding: 8rpx;
  border-radius: 0 0 30rpx 0;
  font-weight: 600;
  z-index: 10;
}

/* 禁用列表项的过渡动画，避免拖拽时的闪烁 */
.todo-item {
  transition:
    transform 0.3s cubic-bezier(0.23, 1, 0.32, 1),
    box-shadow 0.3s ease,
    background 0.5s ease;
}

/* 拖拽时禁用内部点击 */
.todo-item.dragging-disabled {
  pointer-events: none;
}

