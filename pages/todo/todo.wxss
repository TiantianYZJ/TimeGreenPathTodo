/* ===========================
   卡片长按操作 - 原位 cell + 贴边菜单
   =========================== */

/* 遮罩层：全屏半透明黑 */
.card-action-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 12000;
  background: rgba(0, 0, 0, 0.55);
  transition: all 0.2s ease;
}

/* 原位克隆 cell */
.card-action-cell-clone {
  position: fixed;
  z-index: 12001;
  pointer-events: none;
  overflow: hidden;
}

/* ===========================
   操作菜单 - 毛玻璃贴边弹出
   =========================== */

.card-action-menu {
  position: fixed;
  z-index: 12001;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  pointer-events: none;
  box-sizing: border-box;
}

/* 上半屏 cell → 往下弹出 */
.card-action-menu.down {
  opacity: 0;
  transform: translateY(-20rpx);
  transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.card-action-menu.down.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* 下半屏 cell → 往上弹出 */
.card-action-menu.up {
  opacity: 0;
  transform: translateY(20rpx);
  transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.card-action-menu.up.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.menu-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
  transition: background 0.2s ease;
}

.menu-btn:active {
  background: rgba(255, 255, 255, 0.2);
}

.menu-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}
