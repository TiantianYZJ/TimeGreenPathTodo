.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
}

.login-section {
  padding-top: 100rpx;
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
}

.login-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 32rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  gap: 12rpx;
}

.login-btn::after {
  border: none;
}

.user-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #00b26a 0%, #3ddaa0 100%);
  border-radius: 32rpx;
}

.avatar-wrapper {
  position: relative;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.avatar-wrapper::after {
  border: none;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.8);
}

.avatar-edit {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nickname-wrapper {
  margin-top: 20rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.nickname-display {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 32rpx;
}

.user-nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
}

.nickname-edit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.nickname-input {
  width: 400rpx;
  height: 72rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 36rpx;
  text-align: center;
  font-size: 30rpx;
}

.edit-actions {
  display: flex;
  gap: 24rpx;
}

.edit-btn {
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.edit-btn.cancel {
  color: rgba(255,255,255,0.8);
}

.edit-btn.confirm {
  background: rgba(255,255,255,0.9);
  color: #00b26a;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 32rpx;
  background: #fff;
  border-radius: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-limit {
  font-size: 24rpx;
  color: #ccc;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: #f0f0f0;
}

.info-card {
  display: flex;
  flex-direction: column;
  padding: 24rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-family: monospace;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.openid {
  font-size: 22rpx;
  max-width: 360rpx;
}

.menu-card {
  border-radius: 32rpx;
  overflow: hidden;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 30rpx;
  color: #ff4d4f;
}
