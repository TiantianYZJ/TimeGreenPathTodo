<canvas 
  type="2d" 
  id="shareCanvas"
  style="width: 750rpx; height: 1800rpx; position: absolute; left: -9999rpx">
</canvas>

<view style="height:170rpx;">
  <text class="title">统计</text>
</view>

<view class="capture-area">
  <!-- 核心指标卡片 -->
  <view class="container card-style">
    <view class="dashboard">
      <view class="stats-grid">
        <view class="metric-card">
          <text class="metric-value">{{total}}</text>
          <text class="metric-label">总待办</text>
        </view>
        <view class="metric-card accent">
          <text class="metric-value">{{completed}}</text>
          <text class="metric-label">已完成</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{progress}}%</text>
          <text class="metric-label">完成率</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{avgCompletionTime}}</text>
          <text class="metric-label">平均完成时间</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 完成情况概览图表 -->
  <view class="container card-style">
    <view class="visualization-section">
      <text class="chart-title">完成情况概览</text>
      <view class="chart-container">
        <ec-canvas id="overviewChart" ec="{{overviewChart}}" canvas-id="overviewCanvas"></ec-canvas>
      </view>
    </view>
  </view>
  
  <!-- 每日待办趋势图表 -->
  <view class="container card-style">
    <view class="visualization-section">
      <text class="chart-title">每日待办趋势</text>
      <view class="chart-container">
        <ec-canvas id="trendChart" ec="{{trendChart}}" canvas-id="trendCanvas"></ec-canvas>
      </view>
    </view>
  </view>
  
  <!-- 完成时间分布图表 -->
  <view class="container card-style">
    <view class="visualization-section">
      <text class="chart-title">完成时间分布</text>
      <view class="chart-container">
        <ec-canvas id="timeChart" ec="{{timeChart}}" canvas-id="timeCanvas"></ec-canvas>
      </view>
    </view>
  </view>
  
  <!-- 位置分布统计 -->
  <view class="container card-style">
    <view class="visualization-section">
      <text class="chart-title">位置分布</text>
      <view class="bar-chart">
        <view 
          wx:for="{{locationStats}}"
          wx:key="name"
          class="bar-item"
        >
          <view class="bar-container">
            <view 
              class="bar completed" 
              style="width: {{locationTotal > 0 ? (item.count / locationTotal * 100) : 0}}%"
            >
              <text class="location-label">{{item.name}}（{{item.count}}）</text>
            </view>
          </view>
        </view>
      </view>
      <text wx:if="{{!locationMarkers.length}}" class="empty-tip">暂无位置数据</text>
    </view>
  </view>
  
  <!-- 地图可视化 -->
  <view class="container card-style">
    <view class="visualization-section">
      <text class="chart-title">地点分布图</text>
      <map 
        id="locationMap"
        style="width: 100%; height: 500rpx; overflow: hidden; border-radius: 16rpx"
        latitude="{{mapCenter.latitude}}"
        longitude="{{mapCenter.longitude}}"
        markers="{{locationMarkers}}"
        include-points="{{locationPoints}}"
      ></map>
      <text wx:if="{{!locationMarkers.length}}" class="empty-tip">暂无位置标记</text>
    </view>
  </view>
</view>

<t-fab 
  wx:if="{{!isShare}}"
  icon="share" 
  bind:click="generateShareImage"
  style="right: 32rpx; bottom: 32rpx;"
  text="生成报告"
/>
