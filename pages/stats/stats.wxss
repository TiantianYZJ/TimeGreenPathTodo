.title {
  font-size: 50rpx;
  font-weight: 600;
  color: #2d3436;
  flex: 1;
  position: relative;
  left: 30rpx;
  top: 100rpx;
}

.capture-area {
  padding: 0rpx;
  min-height: 100vh;
}

.container {
  margin-bottom: 30rpx;
}

.card-style {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 仪表盘样式 */
.dashboard {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.metric-card {
  background: #fff;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s ease;
}

.metric-card:hover {
  transform: translateY(-4rpx);
}

.metric-card.accent {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.metric-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #2d3436;
  display: block;
  margin-bottom: 10rpx;
}

.metric-label {
  font-size: 28rpx;
  color: #666;
}

/* 可视化区域样式 */
.visualization-section {
  width: 100%;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
  margin-bottom: 20rpx;
  display: block;
}

.chart-container {
  width: 100%;
  height: 400rpx;
  margin: 10rpx 0;
}

/* 柱状图样式 */
.bar-chart {
  flex-direction: column;
  gap: 30rpx;
  margin-top: 30rpx;
}

.bar-item {
  width: 100%;
  height: 60rpx;
  margin-bottom: 20rpx;
}

.bar-container {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
  border-radius: 30rpx;
  overflow: hidden;
  position: relative;
}

.bar.completed {
  height: 100%;
  background: linear-gradient(90deg, #00B26A 0%, #81C784 100%);
  transition: width 0.6s ease-out;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
}

.location-label {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 80%;
}

/* 空数据提示 */
.empty-tip {
  color: #999;
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
}

/* 分享画布样式 */
#shareCanvas {
  position: absolute;
  top: -9999rpx;
  left: -9999rpx;
  width: 600rpx;
  height: 1200rpx;
}

/* 适配不同屏幕尺寸 */
@media screen and (min-width: 768px) {
  .stats-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .chart-container {
    height: 500rpx;
  }
}
