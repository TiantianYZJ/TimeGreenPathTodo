.page {
  min-height: 100vh;
  background: #e3f5eb;
  padding: 80rpx 32rpx 60rpx;
  box-sizing: border-box;
}

.page.qrcode-mode {
  background: linear-gradient(180deg, #e8f8ee 0%, #f0faf4 50%, #ffffff 100%);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
}

.title {
  margin-top: 28rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #2d3436;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6b7a6f;
}

.card {
  margin-top: 60rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.item-text {
  display: flex;
  flex-direction: column;
  margin-left: 32rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #00b26a;
}

.item-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #7a8b80;
}

.agreement-section {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
}

.agreement-link {
  font-size: 24rpx;
  color: #00b26a;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #00b26a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(0, 178, 106, 0.25);
}

.login-btn::after {
  border: none;
}

.login-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.popup-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  padding: 8rpx;
}

.popup-body {
  padding: 24rpx;
  height: calc(80vh - 160rpx);
}

.t-chat-markdown {
  max-width: 95%;
}

.qr-banner {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.qr-banner--info {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  border: 1rpx solid #91d5ff;
}

.qr-banner--setup {
  background: linear-gradient(135deg, #e8f8ee 0%, #d4edda 100%);
  border: 1rpx solid #95de64;
}

.qr-banner-text {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.qr-banner-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
}

.qr-banner-desc {
  font-size: 24rpx;
  color: #595959;
  margin-top: 6rpx;
}

.profile-setup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.profile-avatar-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #00b26a;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.nickname-input:focus {
  border-color: #00b26a;
  outline: none;
}

.profile-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #8c8c8c;
  background: #f5f5f5;
  border-radius: 40rpx;
  border: none;
  font-weight: 500;
}

.btn-secondary::after {
  border: none;
}

.btn-primary {
  flex: 2;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: #00b26a;
  border-radius: 40rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(0, 178, 106, 0.25);
}

.btn-primary::after {
  border: none;
}

.qr-confirm-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 32rpx;
}

.confirm-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f8ee;
  margin-bottom: 24rpx;
}

.confirm-icon-wrap--success {
  animation: scaleIn 0.4s ease-out;
}

@keyframes scaleIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.confirm-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #262626;
  margin-bottom: 8rpx;
}

.confirm-desc {
  font-size: 26rpx;
  color: #8c8c8c;
}

.confirm-user-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.confirm-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e8e8e8;
  margin-right: 20rpx;
}

.confirm-user-info {
  display: flex;
  flex-direction: column;
}

.confirm-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
}

.confirm-id {
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.confirm-warning {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.warning-text {
  font-size: 24rpx;
  color:#d48806;
  margin-left: 12rpx;
  line-height: 1.4;
}

.confirm-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: #00b26a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 46rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 178, 106, 0.35);
  margin-bottom: 20rpx;
}

.confirm-btn::after {
  border: none;
}

.cancel-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: #8c8c8c;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
}

.cancel-btn::after {
  border: none;
}

.success-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx 40rpx;
}

.success-icon-wrap {
  margin-bottom: 32rpx;
  animation: bounceIn 0.6s ease-out;
}

@keyframes bounceIn {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.15);
  }
  70% {
    transform: scale(0.95);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #00b26a;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #595959;
  text-align: center;
  line-height: 1.5;
  max-width: 480rpx;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #00b26a;
  color: #fff;
  font-size: 30rpx;
  border-radius: 50rpx;
  font-weight: 600;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 178, 106, 0.25);
}

.back-btn::after {
  border: none;
}
