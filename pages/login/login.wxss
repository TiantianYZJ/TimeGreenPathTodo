.page {
  min-height: 100vh;
  background: #e3f5eb;
  padding: 80rpx 32rpx 60rpx;
  box-sizing: border-box;
}

/* ===== Hero Section ===== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  position: relative;
  padding-top: 60rpx;
}

.deco-circle {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0,178,106,0.12) 0%, rgba(61,218,160,0.06) 100%);
  z-index: 0;
}

.deco-ring {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,178,106,0.1);
  z-index: 0;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.08);
  position: relative;
  z-index: 1;
  animation: slideInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.title {
  margin-top: 24rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #2d3436;
  position: relative;
  z-index: 1;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #999;
  position: relative;
  z-index: 1;
}

/* ===== Card ===== */
.card {
  margin-top: 48rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.08);
  animation: slideInUp 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.card-item {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.card-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #e8f8ee;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-item-body {
  display: flex;
  flex-direction: column;
  margin-left: 24rpx;
}

.card-item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-item-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.card-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin-bottom: 28rpx;
}

/* ===== Agreement ===== */
.agreement {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 28rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #00b26a;
}

/* ===== Login Button ===== */
.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #00b26a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(0,178,106,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.login-btn::after {
  border: none;
}

.login-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

/* ===== Banner (info card with left border) ===== */
.banner {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.banner--info {
  border-left: 6rpx solid #2dd4bf;
}

.banner--setup {
  border-left: 6rpx solid #00b26a;
}

.banner--warn {
  border-left: 6rpx solid #faad14;
  margin-bottom: 28rpx;
}

.banner-body {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.banner-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
  line-height: 1.4;
  flex: 1;
}

/* ===== Profile Setup ===== */
.profile-setup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.profile-avatar-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #00b26a;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
  border-radius: 44rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
  background: #f5f5f5;
  color: #333;
}

.nickname-input:focus {
  background: #e8f8ee;
  outline: none;
}

.profile-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 44rpx;
  border: none;
  font-weight: 500;
}

.btn-secondary::after {
  border: none;
}

.btn-primary {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: #00b26a;
  border-radius: 44rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(0,178,106,0.25);
}

.btn-primary::after {
  border: none;
}

/* ===== Confirm ===== */
.confirm-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 32rpx;
}

.confirm-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f8ee;
  margin-bottom: 24rpx;
  animation: scaleIn 0.4s ease-out;
}

.confirm-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.confirm-desc {
  font-size: 26rpx;
  color: #999;
}

.confirm-user-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.confirm-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e8e8e8;
  margin-right: 20rpx;
}

.confirm-user-info {
  display: flex;
  flex-direction: column;
}

.confirm-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.confirm-id {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.cancel-btn-wrap {
  text-align: center;
  margin-top: 20rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #999;
  padding: 16rpx 32rpx;
  display: inline-block;
}

/* ===== Success ===== */
.success-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx 40rpx;
}

.success-icon {
  margin-bottom: 32rpx;
  animation: bounceIn 0.6s ease-out;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #00b26a;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
  max-width: 480rpx;
}

/* ===== Popup ===== */
.popup {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  padding: 8rpx;
}

.popup-body {
  padding: 24rpx;
  height: calc(80vh - 160rpx);
}

/* ===== Animations ===== */
@keyframes slideInUp {
  from { transform: translateY(40rpx) scale(0.95); opacity: 0; }
  to { transform: translateY(0) scale(1); opacity: 1; }
}

@keyframes scaleIn {
  from { transform: scale(0); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.15); }
  70% { transform: scale(0.95); }
  100% { transform: scale(1); opacity: 1; }
}
