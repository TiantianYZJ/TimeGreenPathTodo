.page {
  min-height: 100vh;
  background: #e3f5eb;
  padding: 80rpx 40rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ===== Hero ===== */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 16rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.08);
}

.title {
  margin-top: 24rpx;
  font-size: 46rpx;
  font-weight: 700;
  color: #2d3436;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* ===== Comparison Body (pushes bottom down) ===== */
.login-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx 0;
}

.cmp-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.cmp-label {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  text-align: center;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.cmp-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cmp-row:last-child {
  border-bottom: none;
}

.cmp-col {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.cmp-text-before {
  font-size: 26rpx;
  color: #bbb;
}

.cmp-text-after {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.cmp-footer {
  display: block;
  text-align: center;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* ===== Bottom Section ===== */
.login-bottom {
  padding-top: 8rpx;
}

.agreement {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 20rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #999;
}

.agreement-link {
  font-size: 24rpx;
  color: #00b26a;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #00b26a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(0,178,106,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.login-btn::after {
  border: none;
}

.login-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

/* ===== QR Common: Card ===== */
.card {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.08);
}

/* ===== QR Common: Banner ===== */
.banner {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 28rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.banner--info {
  border-left: 6rpx solid #2dd4bf;
}

.banner--setup {
  border-left: 6rpx solid #00b26a;
}

.banner--warn {
  border-left: 6rpx solid #faad14;
  margin-bottom: 28rpx;
}

.banner-body {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.banner-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
  line-height: 1.4;
}

/* ===== Profile Setup ===== */
.profile-setup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
}

.profile-avatar-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  background: transparent;
  border: none;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #00b26a;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
  background: #f5f5f5;
  border-radius: 44rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
  color: #333;
}

.nickname-input:focus {
  background: #e8f8ee;
  outline: none;
}

.profile-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-secondary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  background: #f5f5f5;
  border-radius: 44rpx;
  border: none;
  font-weight: 500;
}

.btn-secondary::after {
  border: none;
}

.btn-primary {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  color: #fff;
  background: #00b26a;
  border-radius: 44rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(0,178,106,0.25);
}

.btn-primary::after {
  border: none;
}

/* ===== QR Confirm ===== */
.confirm-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 32rpx;
}

.confirm-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f8ee;
  margin-bottom: 24rpx;
  animation: scaleIn 0.4s ease-out;
}

.confirm-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.confirm-desc {
  font-size: 26rpx;
  color: #999;
}

.confirm-user-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.confirm-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e8e8e8;
  margin-right: 20rpx;
}

.confirm-user-info {
  display: flex;
  flex-direction: column;
}

.confirm-nickname {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.confirm-id {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.confirm-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: #00b26a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 46rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0,178,106,0.35);
  margin-bottom: 20rpx;
}

.confirm-btn::after {
  border: none;
}

.cancel-btn {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 16rpx;
}

/* ===== Success ===== */
.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx 40rpx;
}

.success-icon {
  margin-bottom: 32rpx;
  animation: bounceIn 0.6s ease-out;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #00b26a;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
  max-width: 480rpx;
}

/* ===== Popup ===== */
.popup {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  padding: 8rpx;
}

.popup-body {
  padding: 24rpx;
  height: calc(80vh - 160rpx);
}

/* ===== Animations ===== */
@keyframes scaleIn {
  from { transform: scale(0); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.15); }
  70% { transform: scale(0.95); }
  100% { transform: scale(1); opacity: 1; }
}
