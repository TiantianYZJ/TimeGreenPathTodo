<view class="container">
  <!-- 选择加密方法 -->
  <view class="picker-container">
    <picker 
      value="{{methodIndex}}" 
      range="{{methods}}" 
      bindchange="bindMethodChange"
      class="method-picker"
    >
      <view class="picker">加密算法：{{methods[methodIndex]}}</view>
    </picker>
    <image src="/images/arrow-right.png" class="picker-arrow" mode="aspectFit" />
  </view>

  <!-- 输入原始文本 -->
  <t-textarea 
    value="{{originalText}}" 
    bind:change="onOriginalTextInput" 
    placeholder="请输入要加密或解密的文本"
    class="text-area"
    autosize="{{true}}"
  />

  <view class="key-group">
    <!-- 新增密钥输入框 -->
    <t-input 
      class="input-area" 
      extra="Slot"
      value="{{secretKey}}" 
      placeholder="请输入密钥"
      tips="{{methods[methodIndex] === 'DES 加密' ? '密钥长度必须为 8 位' : '密钥长度必须为 16、24 或 32 位'}}"
      bind:change="onSecretKeyInput"
      clearable="{{true}}"
      maxcharacter="{{methods[methodIndex] === 'DES 加密' ? 8 : 32}}"
      borderless
    >
    </t-input>

    <view class="key-button-group">
      <button  
        type="primary"
        class="operation-btn"
        bindtap="generateSecretKey"
      >随机密钥</button>
      <button  
        type="primary"
        class="operation-btn"
        bindtap="copySecretKey"
      >复制密钥</button>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="button-group">
    <button 
      type="primary" 
      bindtap="encryptText"
      class="operation-btn"
    >加密</button>
    <button 
      type="primary" 
      bindtap="decryptText"
      class="operation-btn"
    >解密</button>
  </view>

  <!-- 显示加密/解密结果 -->
  <t-textarea 
    value="{{resultText}}" 
    placeholder="加密/解密结果将显示在这里"
    class="text-area"
    readonly
    autosize="{{true}}"
  />

  <!-- 分享按钮 -->
  <button 
    type="primary" 
    bindtap="shareText"
    class="share-btn"
    wx:if="{{resultText}}"
  >一键复制</button>

  <view wx:if="{{message}}" class="message {{messageType}}">{{message}}</view>
</view>


  
  <!-- 加密算法介绍 -->
  <view class="algorithm-intro">
    <text wx:if="{{methods[methodIndex] === 'DES 加密'}}">DES（Data Encryption Standard）是一种对称密钥加密算法，使用 56 位密钥对数据进行加密和解密。该算法采用 Feistel 网络结构，将数据块分成左右两部分，通过多轮迭代和置换操作实现加密。加密和解密使用相同的密钥，安全性依赖于密钥的保密性。</text>
    <text wx:if="{{methods[methodIndex] === 'AES 加密'}}">AES（Advanced Encryption Standard）是一种高级加密标准，属于对称密钥加密算法。分组长度固定为 128 位（16 字节），密钥长度可选择 128 位、192 位或 256 位，对应 10 轮、12 轮和 14 轮加密。加密过程包含字节替换、行移位、列混合和轮密钥加等多轮操作，将明文与密钥深度混淆。解密是加密的逆过程。实际应用中常结合工作模式（如 CBC、GCM 等）和随机数（IV），提升加密的安全性。</text>
  </view>