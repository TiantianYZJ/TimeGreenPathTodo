@import '../todo/todo.wxss';

/* 容器 */
.container {
  margin-top: 24rpx;
  padding: 8rpx;
  padding-bottom: 32rpx;
  min-height: 100vh;
}

/* 卡片样式 */
.card-style {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 日期选择卡片 */
.date-selector-card {
  background: linear-gradient(135deg, #00B26A 0%, #52f099 100%);
  padding: 0;
  overflow: hidden;
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 30rpx;
}

.date-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.date-main {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.date-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 统计卡片 */
.stats-card {
  padding: 0;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 30rpx 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 600;
  color: #2d3436;
}

.stat-value.completed {
  color: #00B26A;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 分区标题 */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3436;
}

/* 时间分布 */
.time-distribution {
  padding: 20rpx 0;
}

.time-bar-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 200rpx;
  padding: 0 10rpx;
}

.time-bar-item {
  width: 24rpx;
  min-height: 8rpx;
  background: linear-gradient(180deg, #00B26A 0%, #81C784 100%);
  border-radius: 8rpx 8rpx 0 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  transition: height 0.3s ease;
  position: relative;
}

.time-bar-label {
  position: absolute;
  top: -36rpx;
  font-size: 20rpx;
  color: #00B26A;
  font-weight: 500;
}

.time-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  padding: 0 6rpx;
}

.time-label {
  font-size: 22rpx;
  color: #999;
}

/* 待办列表 */
.todo-list {
  display: flex;
  flex-direction: column;
}

.todo-item {
  margin: 16rpx 0 !important;
  background: #ffffff !important;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx;
  gap: 16rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 报告画布 */
#reportCanvas {
  position: absolute;
  top: -9999rpx;
  left: -9999rpx;
  width: 750rpx;
  height: 1600rpx;
}

/* 适配不同屏幕尺寸 */
@media screen and (min-width: 768px) {
  .stats-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
