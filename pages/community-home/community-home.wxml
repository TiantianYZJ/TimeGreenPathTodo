<view class="top">
  <view class="header" style="padding-top:{{navBarHeight-44}}px;padding-left:{{menuRight+20}}rpx">
    <text class="title">社区</text>
    <view class="action-group" style="right:{{menuRight + menuWidth + 10}}px">
      <t-icon name="search" size="40rpx" color="#000" bindtap="onSearch" />
    </view>
  </view>
</view>

<scroll-view
  scroll-y
  scroll-top="{{scrollTop}}"
  class="scroll-view"
  style="height: calc(100vh - 170rpx);"
  bind:scroll="onScroll"
  bind:scrolltolower="onLoadMore"
  refresher-enabled="{{true}}"
  refresher-triggered="{{refreshing}}"
  bind:refresherrefresh="onRefresh"
>
  <view class="feed-list">
    <block wx:for="{{postList}}" wx:key="postId">
      <view class="post-card" data-post-id="{{item.postId}}" bind:tap="goToDetail">
        <view class="post-header">
          <image class="post-avatar" src="{{item.user.avatar || '/images/avatar.png'}}" mode="aspectFill" binderror="onAvatarError" />
          <view class="post-user-info">
            <view class="nickname-row">
              <text class="post-nickname">{{item.user.nickname}}</text>
              <block wx:for="{{item.user.badgeTitles || []}}" wx:key="index">
                <text class="user-badge" style="color: {{item.user.badgeColors[index]}}; border-color: {{item.user.badgeColors[index]}}">{{item}}</text>
              </block>
            </view>
            <text class="post-time">{{formatTime(item.createdAt)}}</text>
          </view>
        </view>
        <view class="post-title">{{item.title}}</view>
        <view wx:if="{{item.body}}" class="post-body">{{item.body}}</view>
        <view wx:if="{{item.images && item.images.length > 0}}" class="post-images">
          <view class="grid-{{item.images.length === 1 ? 'single' : (item.images.length === 2 ? 'double' : 'triple')}}">
            <image
              wx:for="{{item.images}}" wx:key="*this"
              src="{{item}}" mode="{{item.images.length === 1 ? 'widthFix' : 'aspectFill'}}"
              class="post-image" catch:tap="previewImage" data-url="{{item}}"
            />
          </view>
        </view>
        <view class="post-meta-row">
          <text wx:if="{{item.ipProvince}}" class="post-ip">IP属地 · {{item.ipProvince}}</text>
        </view>
        <view wx:if="{{item.location}}" class="location-card" catch:tap="openLocation" data-lat="{{item.location.latitude}}" data-lng="{{item.location.longitude}}" data-name="{{item.location.name || item.location}}">
          <t-icon name="location" size="28rpx" color="#00b26a" />
          <text class="location-text">{{item.location.name || item.location.address || item.location.text || item.location}}</text>
        </view>
        <view wx:if="{{item.todoIds && item.todoIds.length > 0 || item.shareCode}}" class="post-tags">
          <view wx:if="{{item.todoIds && item.todoIds.length > 0}}" class="tag-item">
            <t-icon name="checklist" size="22rpx" color="#00b26a" />
            <text>{{item.todoIds.length}}个待办</text>
          </view>
          <view wx:if="{{item.shareCode}}" class="tag-item">
            <t-icon name="user-group" size="22rpx" color="#00b26a" />
            <text>组合</text>
          </view>
        </view>
        <view class="post-stats-row">
          <view class="stat-item" catch:tap="goToDetail" data-post-id="{{item.postId}}">
            <t-icon name="chat" size="28rpx" />
            <text>{{item.commentsCount || 0}}</text>
          </view>
          <view class="stat-item {{item.isLiked ? 'liked' : ''}}" catch:tap="toggleLike" data-post-id="{{item.postId}}">
            <t-icon name="{{item.isLiked ? 'heart-filled' : 'heart'}}" size="28rpx" />
            <text>{{item.likesCount || 0}}</text>
          </view>
          <view class="stat-item">
            <t-icon name="browse" size="28rpx" />
            <text>{{item.viewsCount || 0}}</text>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{loadingMore}}" class="loading-more">
      <t-loading loading="{{true}}" size="40rpx" />
      <text>加载中...</text>
    </view>
    <view wx:if="{{!hasMore && postList.length > 0}}" class="no-more">
      <text>— 没有更多了 —</text>
    </view>
    <view wx:if="{{!loading && postList.length === 0}}" class="empty-state">
      <t-icon name="message" size="100rpx" />
      <text>暂无帖子，快来发布第一条吧</text>
    </view>
  </view>
</scroll-view>

<t-fab wx:if="{{showBackTop}}" icon="arrow-up" bind:click="onToTop" style="right: 32rpx; bottom: 150rpx;" />
<t-fab icon="add" bind:click="goToEdit" style="right: 32rpx; bottom: 32rpx;" />
