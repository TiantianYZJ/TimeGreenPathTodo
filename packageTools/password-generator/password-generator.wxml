<view class="container">
  <view class="header-section">
    <view class="header-icon">
      <t-icon name="lock-on" size="64rpx" color="#fff" />
    </view>
    <text class="header-title">密码生成器</text>
    <text class="header-subtitle">生成安全的随机密码</text>
  </view>

  <view class="card options-card">
    <view class="card-header">
      <t-icon name="setting" size="36rpx" color="#00b26a" />
      <text class="card-title">字符类型</text>
    </view>
    <view class="options-list">
      <view class="option-item" wx:for="{{options}}" wx:key="index">
        <view class="checkbox-wrapper {{item.checked ? 'checked' : ''}}" data-index="{{index}}" bindtap="checkboxChange">
          <t-icon wx:if="{{item.checked}}" name="check" size="32rpx" color="#fff" />
        </view>
        <text class="option-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="card length-card">
    <view class="card-header">
      <t-icon name="ruler" size="36rpx" color="#00b26a" />
      <text class="card-title">密码长度</text>
      <text class="length-value">{{length}} 位</text>
    </view>
    <view class="slider-wrapper">
      <text class="slider-label">4</text>
      <slider 
        class="custom-slider"
        min="4"
        max="64" 
        value="{{length}}" 
        bindchanging="lengthChanging"
        activeColor="#00b26a"
        backgroundColor="#e5e7eb"
        block-size="24"
      />
      <text class="slider-label">64</text>
    </view>
    <view class="length-presets">
      <view class="preset-btn {{length === 8 ? 'active' : ''}}" data-len="8" bindtap="setLength">8位</view>
      <view class="preset-btn {{length === 12 ? 'active' : ''}}" data-len="12" bindtap="setLength">12位</view>
      <view class="preset-btn {{length === 16 ? 'active' : ''}}" data-len="16" bindtap="setLength">16位</view>
      <view class="preset-btn {{length === 24 ? 'active' : ''}}" data-len="24" bindtap="setLength">24位</view>
    </view>
  </view>

  <button class="generate-btn" bindtap="generatePassword">
    <t-icon name="refresh" size="40rpx" color="#fff" />
    <text>生成密码</text>
  </button>

  <view class="card result-card" wx:if="{{password}}">
    <view class="result-header">
      <text class="result-title">生成结果</text>
      <view class="strength-badge {{strength}}">
        <t-icon name="{{strength === 'strong' ? 'check-circle-filled' : strength === 'medium' ? 'info-circle-filled' : 'close-circle-filled'}}" size="28rpx" />
        <text>{{strength === 'weak' ? '弱' : strength === 'medium' ? '中等' : '强'}}</text>
      </view>
    </view>
    
    <view class="password-display">
      <text class="password-text">{{password}}</text>
    </view>
    
    <view class="action-btns">
      <view class="action-btn" bindtap="copyPassword">
        <t-icon name="file-copy" size="36rpx" color="#00b26a" />
        <text>复制</text>
      </view>
      <view class="action-btn" bindtap="generatePassword">
        <t-icon name="refresh" size="36rpx" color="#00b26a" />
        <text>重新生成</text>
      </view>
    </view>
  </view>

  <view class="card tips-card">
    <view class="card-header">
      <t-icon name="info-circle" size="36rpx" color="#00b26a" />
      <text class="card-title">安全说明</text>
    </view>
    <view class="security-notice">
      <t-icon name="check-circle-filled" size="32rpx" color="#10b981" />
      <text>所有密码均在本地生成，不会上传到服务器</text>
    </view>
    
    <view class="strength-guide">
      <text class="guide-title">密码强度说明</text>
      <view class="strength-item weak">
        <view class="strength-indicator"></view>
        <view class="strength-info">
          <text class="strength-name">弱密码</text>
          <text class="strength-time">{{strengthTips.weak.time}}可破解</text>
        </view>
        <text class="strength-desc">{{strengthTips.weak.desc}}</text>
      </view>
      <view class="strength-item medium">
        <view class="strength-indicator"></view>
        <view class="strength-info">
          <text class="strength-name">中等密码</text>
          <text class="strength-time">{{strengthTips.medium.time}}可破解</text>
        </view>
        <text class="strength-desc">{{strengthTips.medium.desc}}</text>
      </view>
      <view class="strength-item strong">
        <view class="strength-indicator"></view>
        <view class="strength-info">
          <text class="strength-name">强密码</text>
          <text class="strength-time">{{strengthTips.strong.time}}可破解</text>
        </view>
        <text class="strength-desc">{{strengthTips.strong.desc}}</text>
      </view>
    </view>
  </view>
</view>
