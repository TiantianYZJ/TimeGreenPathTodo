.container {
  padding: 20rpx 32rpx;
  padding-bottom: 60rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #6b7280;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  flex: 1;
}

.length-value {
  font-size: 28rpx;
  color: #10b981;
  font-weight: 600;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f9fafb;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.checkbox-wrapper {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  transition: all 0.2s ease;
}

.checkbox-wrapper.checked {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-color: transparent;
}

.option-label {
  font-size: 28rpx;
  color: #374151;
}

.slider-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.slider-label {
  font-size: 24rpx;
  color: #9ca3af;
  width: 40rpx;
  text-align: center;
}

.custom-slider {
  flex: 1;
}

.length-presets {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.preset-btn {
  flex: 1;
  min-width: 120rpx;
  padding: 16rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.preset-btn.active {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  font-weight: 500;
}

.generate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
  border: none;
  margin-bottom: 24rpx;
}

.generate-btn:active {
  transform: scale(0.98);
}

.result-card {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border: 2rpx solid #10b981;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.strength-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.strength-badge.weak {
  background: #fef2f2;
  color: #ef4444;
}

.strength-badge.medium {
  background: #fffbeb;
  color: #f59e0b;
}

.strength-badge.strong {
  background: #ecfdf5;
  color: #10b981;
}

.password-display {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.password-text {
  font-size: 32rpx;
  font-family: 'Courier New', monospace;
  color: #1f2937;
  word-break: break-all;
  line-height: 1.6;
  text-align: center;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 32rpx;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn text {
  font-size: 24rpx;
  color: #374151;
}

.tips-card {
  background: #ffffff;
}

.security-notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f0fdf4;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.security-notice text {
  font-size: 26rpx;
  color: #374151;
}

.strength-guide {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.guide-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.strength-item {
  display: flex;
  flex-direction: column;
  padding: 16rpx 20rpx;
  background: #f9fafb;
  border-radius: 32rpx;
  border-left: 6rpx solid transparent;
}

.strength-item.weak {
  border-left-color: #ef4444;
}

.strength-item.medium {
  border-left-color: #f59e0b;
}

.strength-item.strong {
  border-left-color: #10b981;
}

.strength-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.strength-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
}

.strength-time {
  font-size: 22rpx;
  color: #9ca3af;
}

.strength-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}
