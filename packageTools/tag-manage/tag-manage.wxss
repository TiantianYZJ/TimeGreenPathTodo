.container {
  padding: 20rpx;
  padding-bottom: 100rpx;
}

.login-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.login-icon {
  width: 96rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.login-content {
  flex: 1;
}

.login-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.login-text {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.login-btn {
  background: #00b26a;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(0, 178, 106, 0.25);
}

.login-btn::after {
  border: none;
}

.section {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 16rpx;
  height: 16rpx;
  background: #00b26a;
  border-radius: 50%;
  margin-right: 16rpx;
}

.section-hint {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #00b26a;
  background: #e3f5eb;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
}

.add-btn text {
  margin-left: 8rpx;
  font-weight: 500;
}

.tag-list {
  display: flex;
  flex-direction: column;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 32rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  transition: all 0.2s ease;
}

.tag-item:last-child {
  margin-bottom: 0;
}

.tag-item:active {
  background: #f0f0f0;
}

.tag-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tag-name {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.tag-actions {
  display: flex;
  gap: 20rpx;
}

.tag-actions .t-icon {
  padding: 12rpx;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  margin-bottom: 16rpx;
}

.popup-content {
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.form-item {
  margin-bottom: 28rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.color-item {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.color-item.selected {
  transform: scale(1.15);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.2);
}

.popup-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.popup-actions .t-button {
  flex: 1;
  --td-button-border-radius: 32rpx;
}

.tag-input {
  border-radius: 32rpx;
  overflow: hidden;
}
