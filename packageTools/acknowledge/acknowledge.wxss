.container {
  padding: 20rpx 32rpx;
  padding-bottom: 200rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.header-icon {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 178, 106, 0.2);
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #6b7280;
}

.intro-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.intro-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.intro-item text {
  font-size: 28rpx;
  color: #4b5563;
}

.intro-item:not(:last-child) {
  border-bottom: 1rpx solid #f3f4f6;
}

.contributors-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 24rpx;
  display: block;
  padding-left: 8rpx;
}

.contributors-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contributor-card {
  background: #ffffff;
  padding: 28rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.contributor-card:active {
  transform: scale(0.98);
}

.author-card {
  background: linear-gradient(135deg, #ecfdf5 0%, #d1fae5 100%);
  border: 2rpx solid #10b981;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.contributor-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 178, 106, 0.2);
}

.author-badge {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.3);
}

.contributor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 4rpx;
}

.contributor-name {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.contribution-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.contribution-tag {
  font-size: 24rpx;
  color: #fff;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #34d399 0%, #10b981 100%);
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.25);
}

.author-card .contribution-tag {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
}

.footer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.footer-divider {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #d1d5db, transparent);
  margin-bottom: 32rpx;
}

.footer-text {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 16rpx;
}

.footer-thanks {
  font-size: 28rpx;
  color: #10b981;
  font-weight: 500;
}
