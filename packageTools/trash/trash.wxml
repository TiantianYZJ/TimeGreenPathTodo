<view class="container">
  <view class="header-section">
    <view class="header-icon">
      <t-icon name="delete" size="64rpx" color="#fff" />
    </view>
    <text class="header-title">回收站</text>
    <text class="header-subtitle">已删除的待办将保留30天</text>
  </view>

  <view class="warning-card">
    <view class="warning-icon">
      <t-icon name="info-circle-filled" size="40rpx" color="#f59e0b" />
    </view>
    <view class="warning-content">
      <text class="warning-title">自动清除提醒</text>
      <text class="warning-text">超过30天的已删除待办将自动永久清除，无法恢复</text>
    </view>
  </view>

  <view wx:if="{{!isLoggedIn}}" class="login-card">
    <view class="login-icon">
      <t-icon name="user" size="48rpx" color="#10b981" />
    </view>
    <view class="login-content">
      <text class="login-title">登录同步数据</text>
      <text class="login-text">登录后可查看云端回收站数据</text>
    </view>
    <button class="login-btn" bindtap="goLogin">立即登录</button>
  </view>

  <view wx:if="{{deletedTodos.length === 0}}" class="empty-section">
    <view class="empty-icon">
      <t-icon name="check-circle-filled" size="120rpx" color="#d1d5db" />
    </view>
    <text class="empty-title">回收站是空的</text>
    <text class="empty-text">没有已删除的待办事项</text>
  </view>

  <view wx:else class="todo-list">
    <view class="list-header">
      <text class="list-title">已删除待办</text>
      <text class="list-count">{{deletedTodos.length}}项</text>
    </view>
    
    <view class="todo-item" wx:for="{{deletedTodos}}" wx:key="id">
      <view class="todo-header">
        <text class="todo-title">{{item.text}}</text>
        <view class="days-badge {{item.daysLeft <= 3 ? 'warning' : item.daysLeft <= 7 ? 'notice' : ''}}">
          <text>{{item.daysLeft}}天后清除</text>
        </view>
      </view>
      
      <view class="todo-meta">
        <view class="meta-item">
          <t-icon name="calendar" size="28rpx" color="#9ca3af" />
          <text>截止日期: {{item.setDate || '未设置'}}</text>
        </view>
        <view class="meta-item">
          <t-icon name="time" size="28rpx" color="#9ca3af" />
          <text>删除于: {{item.deletedAtStr}}</text>
        </view>
      </view>
      
      <view class="todo-actions">
        <button class="action-btn restore" data-index="{{index}}" bindtap="restoreTodo">
          <t-icon name="undo" size="32rpx" color="#10b981" />
          <text>恢复</text>
        </button>
        <button class="action-btn delete" data-index="{{index}}" bindtap="permanentDelete">
          <t-icon name="delete" size="32rpx" color="#ef4444" />
          <text>永久删除</text>
        </button>
      </view>
    </view>
  </view>
</view>
