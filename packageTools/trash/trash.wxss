.container {
  padding: 20rpx 32rpx;
  padding-bottom: 60rpx;
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #6b7280;
}

.warning-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.warning-icon {
  flex-shrink: 0;
}

.warning-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.warning-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
}

.warning-text {
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.5;
}

.login-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.login-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.login-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.login-text {
  font-size: 24rpx;
  color: #6b7280;
}

.login-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.login-btn:active {
  transform: scale(0.95);
}

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
  margin-bottom: 8rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.list-count {
  font-size: 24rpx;
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.todo-item {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(239, 68, 68, 0.1);
}

.todo-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.todo-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
  word-break: break-all;
  line-height: 1.4;
}

.days-badge {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  background: #f3f4f6;
  border-radius: 32rpx;
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 500;
}

.days-badge.notice {
  background: #fef3c7;
  color: #92400e;
}

.days-badge.warning {
  background: #fee2e2;
  color: #dc2626;
}

.todo-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.todo-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 0;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.restore {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #059669;
}

.action-btn.delete {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #dc2626;
}
