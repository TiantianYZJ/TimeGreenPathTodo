@import "../../pages/todo/todo.wxss";
.search-input {
  flex: 1;
}

.empty-tips {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 28rpx;
}

.search-container {
  padding-top: 8rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #e3f5eb99;
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
}

.search-count {
  display: block;
  font-size: 27rpx;
  color: #666;
  padding: 15rpx 16rpx;
  text-align: left;
}

.container {
  padding-top: 148rpx;
  padding-bottom: 400rpx;
  overflow-y: auto;
}

.highlight {
  color: #e64340;
  font-weight: 500;
}

/* 覆盖 @import 导入的 .todo-item 伪元素色条（在子包中改用 wrapper::before） */
.todo-item-wrapper[data-priority] .todo-item::before,
.todo-item-wrapper:not([data-priority]) .todo-item::before {
  content: none;
}

/* ===========================
   优先级左侧弧度色条
   =========================== */
.todo-item-wrapper {
  overflow: hidden;
  position: relative;
}
.todo-item-wrapper[data-priority="p1"]::before {
  background: #e34d4d;
}
.todo-item-wrapper[data-priority="p2"]::before {
  background: #2196F3;
}
.todo-item-wrapper[data-priority="p3"]::before {
  background: #FF9800;
}
.todo-item-wrapper[data-priority="p4"]::before {
  background: #999;
}
.todo-item-wrapper:not([data-priority])::before {
  background: transparent;
}
.todo-item-wrapper[data-priority]::before {
  content: '';
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: calc(100% - 28rpx);
  border-radius: 0 4rpx 4rpx 0;
  z-index: 1;
}