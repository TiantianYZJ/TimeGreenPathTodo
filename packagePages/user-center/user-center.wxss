/* ========================================
   个人中心 - 时光绿径待办
   设计语言：清新自然 · 卡片化 · 微交互
   ======================================== */

/* ---------- 全局 ---------- */
.container {
  min-height: 100vh;
  padding: 0 20rpx 120rpx;
  position: relative;
}

/* ========== 登录态 ========== */
.login-section {
  padding-top: 120rpx;
  position: relative;
  overflow: hidden;
}

/* 装饰性背景圆 */
.login-decor {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  pointer-events: none;
}

.decor-circle {
  position: absolute;
  border-radius: 50%;
}

.decor-c1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(0, 178, 106, 0.12) 0%, transparent 70%);
  top: -100rpx;
  left: -50rpx;
}

.decor-c2 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(16, 185, 129, 0.08) 0%, transparent 70%);
  top: 80rpx;
  right: -80rpx;
}

.decor-c3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(45, 212, 191, 0.08) 0%, transparent 70%);
  bottom: -40rpx;
  left: 50%;
  transform: translateX(-50%);
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 48rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 1;
  box-shadow: 0 8rpx 40rpx rgba(0, 178, 106, 0.1);
}

.login-avatar-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: linear-gradient(135deg, #00b26a, #3ddaa0);
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #00b26a 0%, #06ad56 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 178, 106, 0.3);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0, 178, 106, 0.2);
}

.login-btn::after {
  border: none;
}

.login-hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 24rpx;
}

/* ========== 已登录态 ========== */
.user-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 0;
}

/* --- 顶部个人资料卡片 --- */
.profile-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #00b26a 0%, #2ddaa0 100%);
  box-shadow: 0 8rpx 32rpx rgba(0, 178, 106, 0.2);
}

.profile-bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-blob {
  position: absolute;
  border-radius: 50%;
}

.blob-1 {
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  top: -120rpx;
  right: -80rpx;
}

.blob-2 {
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  bottom: -60rpx;
  left: -60rpx;
}

.profile-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx 32rpx;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  flex-shrink: 0;
  width: 138rpx;
  height: 138rpx;
}

.avatar-wrapper::after {
  border: none;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.85);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  background: #f0f0f0;
}

.avatar-edit-badge {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.4);
  border: 3rpx solid rgba(255,255,255,0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.greeting-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.greeting-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 400;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.user-nickname {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-nickname.placeholder {
  font-weight: 400;
  opacity: 0.7;
}

.name-edit-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
}

.name-edit-btn:active {
  background: rgba(255,255,255,0.15);
}

/* 昵称编辑态 */
.nickname-edit-bar {
  margin-top: 16rpx;
  animation: editSlideDown 0.25s ease;
}

@keyframes editSlideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.nickname-edit-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  background: rgba(255,255,255,0.95);
  border-radius: 36rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.edit-actions {
  display: flex;
  gap: 24rpx;
}

.edit-btn {
  font-size: 28rpx;
  padding: 10rpx 32rpx;
  border-radius: 28rpx;
  font-weight: 500;
}

.edit-btn.cancel {
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.12);
}

.edit-btn.confirm {
  background: #fff;
  color: #00b26a;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.daily-motto {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.15);
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  text-align: center;
  line-height: 1.5;
}

/* --- 成长数据卡片 --- */
.growth-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.growth-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.growth-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.growth-stats {
  display: flex;
  align-items: center;
}

.growth-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.growth-stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.growth-stat-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.growth-stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.1;
}

.growth-stat-label {
  font-size: 22rpx;
  color: #999;
}

.growth-stat-divider {
  width: 1rpx;
  height: 72rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

/* --- 快捷操作网格 --- */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.action-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.action-hover {
  transform: scale(0.96) !important;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04) !important;
}

.action-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.action-desc {
  font-size: 22rpx;
  color: #bbb;
}

/* --- 账号信息（可折叠） --- */
.collapse-section {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.collapse-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.collapse-header:active {
  background: #fafafa;
}

.collapse-header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.collapse-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.collapse-body {
  padding: 0 32rpx 24rpx;
  animation: collapseFadeIn 0.25s ease;
}

@keyframes collapseFadeIn {
  from {
    opacity: 0;
    transform: translateY(-8rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.info-divider {
  height: 1rpx;
  background: #f5f5f5;
  margin: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 65%;
  padding: 8rpx 14rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.info-value-wrap:active {
  background: #f0f0f0;
}

.info-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.openid {
  font-size: 20rpx;
}

/* --- 退出登录 --- */
.logout-section {
  margin-top: 8rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.2s ease, background 0.2s ease;
}

.logout-hover {
  transform: scale(0.98) !important;
  background: #fafafa !important;
}

.logout-text {
  font-size: 28rpx;
  color: #e34d59;
  font-weight: 500;
}

/* ========== 入场动画 ========== */
.user-section {
  animation: sectionFadeIn 0.4s ease;
}

@keyframes sectionFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-card {
  animation: cardFloatIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes cardFloatIn {
  from {
    opacity: 0;
    transform: translateY(30rpx) scale(0.97);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

/* 逐项入场动画（利用 stagger 效果） */
.growth-card {
  animation: slideUp 0.4s ease 0.05s both;
}

.action-item:nth-child(1) {
  animation: slideUp 0.4s ease 0.1s both;
}
.action-item:nth-child(2) {
  animation: slideUp 0.4s ease 0.15s both;
}
.action-item:nth-child(3) {
  animation: slideUp 0.4s ease 0.2s both;
}
.action-item:nth-child(4) {
  animation: slideUp 0.4s ease 0.25s both;
}

.collapse-section {
  animation: slideUp 0.4s ease 0.3s both;
}

.logout-section {
  animation: slideUp 0.4s ease 0.35s both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
