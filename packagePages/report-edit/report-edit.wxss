/* ========== 滚动区域 ========== */
.scroll-area {
  height: 100vh;
}

.container {
  padding: 0 32rpx 160rpx;
}

/* ========== 日期提示 ========== */
.page-title {
  font-size: 48rpx;
  font-weight: 600;
  line-height: 1.5;
  color: #333;
  padding: 10rpx 0 20rpx 0;
  display: block;
}

/* ========== 表单项（对标 add-todo） ========== */
.form-item {
  padding-bottom: 32rpx;
}

.question-title {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1.1;
  color: #333;
  margin-bottom: 15rpx;
  padding-left: 32rpx;
  position: relative;
}

.question-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  background: #00b26a;
  border-radius: 50%;
}

/* ========== 组合选择器（对标 add-todo） ========== */
.combo-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  margin-left: 24rpx;
  background: #f8f8f8;
  border-radius: 32rpx;
}

.selected-combo {
  flex: 1;
}

.combo-name-text {
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 区块容器 ========== */
.sections-container {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ========== 行编辑 ========== */
.lines-container {
  display: flex;
  flex-direction: column;
  margin-left: 24rpx;
}

.line-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
  gap: 12rpx;
}

.line-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  background: #f8f8f8;
  border-radius: 32rpx;
  padding: 16rpx 20rpx;
  min-height: 60rpx;
  box-sizing: border-box;
  word-break: break-all;
}

.line-textarea:focus {
  background: #eefaf4;
}

.line-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.line-action-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.line-action-btn.todo-btn {
  width: auto;
  height: auto;
  border-radius: 32rpx;
  background: #e3f5eb;
  border: 1rpx solid #00b26a;
  padding: 8rpx 18rpx;
  gap: 4rpx;
}

.todo-btn-text {
  font-size: 24rpx;
  color: #00b26a;
  font-weight: 600;
}

.line-action-btn:active {
  transform: scale(0.9);
}

.line-action-btn.delete-btn {
  background: #fff0f0;
}

/* ========== 区块操作 ========== */
.section-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 12rpx;
  margin-left: 24rpx;
}

.section-action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  background: #f0faf5;
  transition: all 0.2s ease;
}

.section-action-btn:active {
  transform: scale(0.97);
  background: #ddf5e8;
}

.section-action-btn.primary {
  background: #e3f5eb;
}

.action-text {
  font-size: 26rpx;
  color: #00b26a;
  font-weight: 500;
}

/* ========== 底部安全区域 ========== */
.bottom-safe {
  height: 160rpx;
}

/* ========== 周报提示（像 add-todo voice-tip 一样） ========== */
.weekly-hint {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f0faf5;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.weekly-hint-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.weekly-hint-text {
  color: #00b26a;
  font-size: 28rpx;
}

/* ========== 组合选择 Popup（对标 add-todo） ========== */
.combo-picker-content {
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  padding: 8rpx;
}

.popup-scroll {
  flex: 1;
  padding: 20rpx 32rpx;
  max-height: 60vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.picker-section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.picker-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 32rpx;
  margin-bottom: 16rpx;
  gap: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
  transition: all 0.2s ease;
}

.picker-option:active {
  transform: scale(0.98);
}

.picker-option.selected {
  background: #e3f5eb;
}

.option-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
  overflow: hidden;
}

.option-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-combos {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* ========== 待办导入 Popup ========== */
.import-popup-content {
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.import-search-area {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.import-scroll {
  flex: 1;
  padding: 16rpx 32rpx;
  max-height: 55vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.import-section {
  margin-bottom: 24rpx;
}

.import-section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.import-todo-item {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  background: #f8f8f8;
  border-radius: 32rpx;
  margin-bottom: 10rpx;
  gap: 16rpx;
  transition: all 0.2s ease;
}

.import-todo-item:active {
  transform: scale(0.98);
}

.import-todo-item.selected {
  background: #e3f5eb;
}

.import-todo-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.import-confirm-area {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom, 0rpx));
  border-top: 1rpx solid #f0f0f0;
}
