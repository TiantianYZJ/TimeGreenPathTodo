/* ========== 滚动区域 ========== */
.scroll-area {
  height: 100vh;
  box-sizing: border-box;
}

/* ========== 目标选择器 ========== */
.target-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  margin: 20rpx 24rpx 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.target-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.target-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.target-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.target-name {
  font-size: 30rpx;
  color: #00b26a;
  font-weight: 500;
}

.target-hint {
  font-size: 24rpx;
  color: #999;
  padding: 0 12rpx 20rpx 24rpx;
}

/* ========== 区块卡片 ========== */
.sections-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx 24rpx 0;
}

.section-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx 28rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

/* 区块标题 */
.section-header {
  margin-bottom: 16rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-color-tag {
  width: 8rpx;
  height: 28rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-badge {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 32rpx;
  margin-left: auto;
}

/* ========== 行编辑 ========== */
.lines-container {
  display: flex;
  flex-direction: column;
}

.line-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  gap: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.line-item:last-child {
  border-bottom: none;
}

.line-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  background: #fafafa;
  border-radius: 32rpx;
  padding: 12rpx 16rpx;
  min-height: 60rpx;
  box-sizing: border-box;
  word-break: break-all;
}

.line-textarea:focus {
  background: #eefaf4;
}

.line-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.line-action-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.line-action-btn.todo-btn {
  width: auto;
  height: auto;
  border-radius: 32rpx;
  background: #e3f5eb;
  border: 1rpx solid #00b26a;
  padding: 8rpx 18rpx;
  gap: 4rpx;
}

.todo-btn-text {
  font-size: 24rpx;
  color: #00b26a;
  font-weight: 600;
}

.line-action-btn:active {
  transform: scale(0.9);
}

.line-action-btn.delete-btn {
  background: #fff0f0;
}

/* ========== 区块操作 ========== */
.section-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 4rpx;
}

.section-action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 32rpx;
  background: #f0faf5;
  transition: all 0.2s ease;
}

.section-action-btn:active {
  transform: scale(0.97);
  background: #ddf5e8;
}

.section-action-btn.primary {
  background: #e3f5eb;
}

.action-text {
  font-size: 26rpx;
  color: #00b26a;
  font-weight: 500;
}

/* ========== 底部安全区域 ========== */
.bottom-safe {
  height: 160rpx;
}

/* ========== 组合选择 Popup ========== */
.combo-picker-content {
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  padding: 8rpx;
}

.mode-options {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.combo-list-scroll {
  flex: 1;
  padding: 20rpx 32rpx;
  max-height: 55vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.combo-options {
  margin-bottom: 16rpx;
}

.combo-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 32rpx;
  margin-bottom: 16rpx;
  gap: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
  transition: all 0.2s ease;
}

.combo-card:active {
  transform: scale(0.98);
}

.combo-card.selected {
  background: #e3f5eb;
  border: 1rpx solid #00b26a;
}

.combo-card-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.combo-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
  overflow: hidden;
}

.combo-card-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.combo-card-count {
  font-size: 24rpx;
  color: #999;
}

.combo-confirm-area {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom, 0rpx));
  border-top: 1rpx solid #f0f0f0;
}

.empty-combos {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* TDesign component overrides */
page {
  --td-cell-bg-color: #e3f5eb;
  --td-radio-bg-color: transparent;
}

/* ========== 待办导入 Popup ========== */
.import-popup-content {
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(24rpx) saturate(180%);
  -webkit-backdrop-filter: blur(24rpx) saturate(180%);
  border-radius: 32rpx 32rpx 0 0;
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.import-search-area {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.import-scroll {
  flex: 1;
  padding: 16rpx 32rpx;
  max-height: 55vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.import-section {
  margin-bottom: 24rpx;
}

.import-section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.import-todo-item {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  background: #f8f8f8;
  border-radius: 32rpx;
  margin-bottom: 10rpx;
  gap: 16rpx;
  transition: all 0.2s ease;
}

.import-todo-item:active {
  transform: scale(0.98);
}

.import-todo-item.selected {
  background: #e3f5eb;
}

.import-todo-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.import-confirm-area {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom, 0rpx));
  border-top: 1rpx solid #f0f0f0;
}
