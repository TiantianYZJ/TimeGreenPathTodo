/* ===== Page Container ===== */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #e3f5eb;
}

/* ===== Scroll Area ===== */
.scroll-area {
  flex: 1;
  padding: 0 24rpx 160rpx;
  box-sizing: border-box;
}

/* ===== Loading ===== */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #00b26a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* ===== Empty ===== */
.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* ===== Meta Section ===== */
.meta-section {
  background: #fff;
  border-radius: 32rpx;
  padding: 0 24rpx;
  margin-top: 24rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-label {
  font-size: 28rpx;
  color: #999;
}

.meta-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.meta-badge-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* ===== Section Cards ===== */
.sections-area {
  margin-top: 24rpx;
}

.section-card {
  background: #fff;
  border-radius: 32rpx;
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.section-color-tag {
  width: 8rpx;
  flex-shrink: 0;
}

.section-body {
  flex: 1;
  padding: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-lines {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.section-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.bullet-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 10rpx;
}

.line-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  word-break: break-all;
}

.section-empty {
  padding: 20rpx 0 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #bbb;
}

/* ===== Time Info ===== */
.time-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.time-row {
  font-size: 24rpx;
  color: #bbb;
}

/* ===== Delete Button ===== */
.delete-area {
  margin-top: 24rpx;
  padding-bottom: 48rpx;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #ff4d4f;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #ff4d4f;
  padding: 0;
}

.delete-btn::after {
  border: none;
}

/* TDesign component overrides */
page {
  --td-cell-bg-color: #e3f5eb;
  --td-radio-bg-color: transparent;
}
