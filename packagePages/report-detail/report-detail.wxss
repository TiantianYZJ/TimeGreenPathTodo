.form-item {
  padding-bottom: 160rpx;
}

.container {
  padding: 30rpx;
  padding-top: 25rpx;
}

/* ===== Loading ===== */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #00b26a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* ===== Empty ===== */
.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

/* ===== Card ===== */
.date-info {
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  padding: 25rpx;
  background: linear-gradient(150deg, #f9f9f9 0%, #f1f1f1 100%);
  border-radius: 32rpx;
}

.date-info.deadline {
  background: linear-gradient(150deg, #f9f9f9 0%, #f6f0c5 100%);
}

.label {
  color: #666;
  font-size: 34rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  line-height: 34rpx;
}

.value {
  color: #333;
  font-size: 34rpx;
  word-break: break-all;
  line-height: 1.6;
  text-indent: 0;
  display: inline;
}

.scope-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* ===== Section Cards ===== */
.sections-area {
  margin-top: 24rpx;
}

.section-card {
  background: linear-gradient(150deg, #f9f9f9 0%, #f1f1f1 100%);
  border-radius: 32rpx;
  display: flex;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.section-color-tag {
  width: 8rpx;
  flex-shrink: 0;
}

.section-body {
  flex: 1;
  padding: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-lines {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.section-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bullet-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.line-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  word-break: break-all;
}

.section-empty {
  padding: 20rpx 0 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: #bbb;
}

/* ===== Time Info ===== */
.time-info {
  margin-top: 24rpx;
}

.time-row {
  display: flex;
  align-items: center;
}

.time-col {
  flex: 1;
  min-width: 0;
}

.time-divider {
  width: 2rpx;
  height: 48rpx;
  background: #e0e0e0;
  margin: 0 24rpx;
  flex-shrink: 0;
}

.time-value {
  font-size: 26rpx;
  color: #999;
}

/* ===== Delete Button ===== */
.delete-area {
  margin-top: 40rpx;
  padding-bottom: 48rpx;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #ff4d4f;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #ff4d4f;
  padding: 0;
}

.delete-btn::after {
  border: none;
}

/* ===== Section Header: 统一卡片图标+标签排布 ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.section-header .label {
  margin-right: 0;
  margin-bottom: 0;
  display: inline;
}
