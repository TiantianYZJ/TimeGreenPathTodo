<view class="container">
  <view class="form-item">
    <!-- 加载态 -->
    <view wx:if="{{!loaded}}" class="loading-area">
      <view class="loading-spinner" />
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空态 -->
    <view wx:if="{{loaded && !report}}" class="empty-area">
      <t-icon name="file" size="80rpx" color="#ddd" />
      <text class="empty-text">报告不存在</text>
    </view>

    <block wx:if="{{loaded && report}}">
      <!-- 日期 -->
      <view class="date-info deadline">
        <view class="section-header">
          <t-icon name="time" size="32rpx" color="#999" />
          <text class="label">日期</text>
        </view>
        <text class="value">{{friendlyDate}}</text>
      </view>

      <!-- 报告类型 -->
      <view class="date-info">
        <view class="section-header">
          <t-icon name="edit" size="32rpx" color="#999" />
          <text class="label">类型</text>
        </view>
        <text class="value">{{reportType === 'weekly' ? '周报' : '日报'}}</text>
      </view>

      <!-- 归属 -->
      <view class="date-info">
        <view class="section-header">
          <t-icon name="user" size="32rpx" color="#999" />
          <text class="label">归属</text>
        </view>
        <view class="scope-badge">
          <t-icon wx:if="{{report.scope === 'private'}}" name="lock-on" size="28rpx" color="#00b26a" />
          <t-icon wx:else name="user-group" size="28rpx" color="#00b26a" />
          <text class="value">{{report.scope === 'private' ? '个人报告' : '团队报告'}}</text>
        </view>
      </view>

      <!-- 报告内容区块 -->
      <view class="sections-area">
        <view class="section-card" wx:for="{{sections}}" wx:key="key" wx:for-index="idx">
          <view class="section-color-tag" style="background: {{sectionColors[idx % sectionColors.length]}}" />
          <view class="section-body">
            <text class="section-title">{{item.title || '未命名区块'}}</text>
            <view wx:if="{{item.lines && item.lines.length > 0}}" class="section-lines">
              <view class="section-line" wx:for="{{item.lines}}" wx:key="*this">
                <view class="bullet-dot" style="background: {{sectionColors[idx % sectionColors.length]}}" />
                <text class="line-text">{{item}}</text>
              </view>
            </view>
            <view wx:else class="section-empty">
              <text>暂无记录</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 时间信息 -->
      <view class="time-info date-info">
        <view class="time-row">
          <view class="time-col">
            <view class="section-header">
              <t-icon name="add" size="26rpx" color="#bbb" />
              <text class="label">创建时间</text>
            </view>
            <text class="value time-value">{{formattedCreatedAt || '-'}}</text>
          </view>
          <view class="time-divider" />
          <view class="time-col">
            <view class="section-header">
              <t-icon name="time" size="26rpx" color="#bbb" />
              <text class="label">更新时间</text>
            </view>
            <text class="value time-value">{{formattedUpdatedAt || '-'}}</text>
          </view>
        </view>
      </view>

      <!-- 删除 -->
      <view wx:if="{{canDelete}}" class="delete-area">
        <button class="delete-btn" bindtap="deleteReport">删除报告</button>
      </view>
    </block>
  </view>
</view>

<!-- 编辑 FAB -->
<view wx:if="{{canEdit}}">
  <t-fab icon="edit-1" text="编辑" bind:click="navigateToEdit" style="right: 32rpx; bottom: 32rpx;" />
</view>
