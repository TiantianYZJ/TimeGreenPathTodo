/* Tab bar */
.tab-bar {
  display: flex;
  border-radius: 32rpx;
  padding: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 32rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #ccebda;
  color: #00b26a;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* Preview card */
.preview-card {
  background: #f9fff9;
  border-radius: 32rpx;
  padding: 24rpx;
  margin: 24rpx;
  height: 32vh;
}

.preview-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.preview-subtasks {
  font-size: 32rpx;
  color: #666;
  white-space: pre-line;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.preview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.preview-meta text {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.btn-generate {
  background: #00b26a;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  padding: 18rpx;
  margin: 40rpx;
  border-radius: 32rpx;
}

/* Inline input inside cell */
.settings-section {
  border-radius: 32rpx;
  overflow: hidden;
}

.t-cell {
  --td-cell-bg-color: #e3f5eb;
  --td-cell-height: 128rpx;
}

.t-input {
  --td-input-bg-color: #ccebda;
  border-radius: 32rpx;
}

.cell-input {
  width: 100%;
}

.cell-input-right {
  text-align: right;
  color: #333;
}

.cell-input-small {
  width: 200rpx;
  text-align: right;
}

.switch-inline {
  display: inline-flex;
  align-items: center;
}

/* Action section (after generation) */
.action-section {
  background: #00b26a;
  font-size: 32rpx;
  margin: 36rpx;
  border-radius: 32rpx;
}

/* Community tab */
.community-desc {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin: 32rpx 0;
}

.community-btn-area {
  background: #00b26a;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  padding: 18rpx;
  margin: 36rpx;
  border-radius: 32rpx;
}

