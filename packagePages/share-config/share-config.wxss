.page {
  padding: 20rpx;
  min-height: 100vh;
  background: #f8f9fa;
}

/* Tab bar */
.tab-bar {
  display: flex;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 4rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #fff;
  color: #00b26a;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* Preview card */
.preview-card {
  background: #f9fff9;
  border: 1rpx solid #e0f5e6;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.preview-subtasks {
  font-size: 26rpx;
  color: #666;
  white-space: pre-line;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.preview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
}

.preview-meta text {
  background: #f0faf0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* Settings section */
.settings-section {
  margin-bottom: 24rpx;
}

.settings-section .btn-generate {
  margin-top: 40rpx;
}

/* Inline input inside cell */
.cell-input {
  width: 100%;
}

.cell-input-right {
  text-align: right;
  color: #333;
}

.cell-input-small {
  width: 200rpx;
  text-align: right;
}

.cell-description {
  font-size: 22rpx;
  color: #999;
  padding: 0 32rpx 16rpx;
  margin-top: -8rpx;
}

.switch-inline {
  display: inline-flex;
  align-items: center;
}

/* Action section (after generation) */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 40rpx;
}

/* Community tab */
.community-desc {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin: 32rpx 0;
}

.community-btn-area {
  margin-top: 40rpx;
}

